.page {
  min-height: 100vh;
  background: #FEF9F3;
}

.profile-header {
  position: relative;
  background: linear-gradient(135deg, #A0301F 0%, #D32F2F 100%);
  padding: calc(env(safe-area-inset-top) + 60rpx) 32rpx 80rpx;
  overflow: hidden;
}

.header-deco {
  position: absolute;
  top: -40rpx;
  right: -40rpx;
  width: 280rpx;
  height: 280rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
}

.user-row {
  display: flex;
  align-items: center;
  position: relative;
  z-index: 1;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.8);
}

.user-info {
  margin-left: 24rpx;
}

.nickname {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
}

.user-id {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.75);
  margin-top: 8rpx;
}

.guest-hint {
  color: rgba(255, 255, 255, 0.9);
  text-decoration: underline;
}

.stats-row {
  display: flex;
  justify-content: space-around;
  margin-top: 40rpx;
  position: relative;
  z-index: 1;
}

.stat-item {
  text-align: center;
}

.stat-num {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
}

.stat-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 4rpx;
}

.content-card {
  margin: -40rpx 32rpx 0;
  background: #fff;
  border-radius: 40rpx 40rpx 0 0;
  padding: 16rpx 0 40rpx;
  position: relative;
  z-index: 2;
  min-height: 60vh;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 32rpx 40rpx;
  border-bottom: 1rpx solid #F0EBE3;
}

.menu-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 24rpx;
  border: 3rpx solid #A0522D;
  border-radius: 8rpx;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
}

.menu-arrow {
  font-size: 32rpx;
  color: #ccc;
}

.menu-extra {
  font-size: 26rpx;
  color: #8B7D6B;
  margin-right: 8rpx;
}

.icon-lang {
  border-radius: 50%;
}

.icon-exp {
  border-radius: 50%;
  background: rgba(160, 48, 31, 0.08);
}
