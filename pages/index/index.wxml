<view class="page v0-page page-fade-in safe-bottom">
  <page-deco />
  <view class="page-body">
  <view class="v0-header" style="padding-top: {{navPaddingTop}}px; padding-right: {{headerPaddingRight}}px;">
    <view class="header-top-row">
      <view class="location-row tap-active" bindtap="goCitySelect">
        <image class="location-pin" src="/images/icons/location-pin.png" mode="aspectFit" />
        <text class="location-text">{{displayCity}}</text>
      </view>
      <view class="v0-search tap-active" bindtap="goSearch">
        <text class="v0-search-icon">⌕</text>
        <text class="v0-search-placeholder">{{i18n.searchPlaceholder}}</text>
      </view>
    </view>
  </view>

  <swiper
    class="hero-swiper"
    indicator-dots
    indicator-color="rgba(255,255,255,0.45)"
    indicator-active-color="#ffffff"
    autoplay
    circular
    interval="4000"
    duration="500"
  >
    <swiper-item wx:for="{{banners}}" wx:key="id" class="hero-slide">
      <view class="hero-card tap-active" data-id="{{item.targetId}}" bindtap="goBanner">
        <image class="hero-img" src="{{item.image}}" mode="scaleToFill" lazy-load="{{false}}" />
      </view>
    </swiper-item>
  </swiper>

  <view class="today-section">
    <view class="today-header">
      <view class="title-bar">
        <view class="title-bar-mark"></view>
        <text class="today-title title-serif">{{i18n.todayTitle}}</text>
        <text class="today-sub">{{i18n.todaySubtitle}}</text>
      </view>
    </view>

    <view class="today-tabs">
      <view
        class="today-tab {{todayTab === 'legend' ? 'active' : ''}}"
        data-tab="legend"
        bindtap="onTodayTab"
      >
        <text>{{i18n.todayLegend}}</text>
      </view>
      <view class="today-tab-sep" aria-hidden="true">
        <view class="today-tab-dot"></view>
        <view class="today-tab-dot"></view>
        <view class="today-tab-dot"></view>
        <view class="today-tab-dot"></view>
        <view class="today-tab-dot"></view>
        <view class="today-tab-dot"></view>
      </view>
      <view
        class="today-tab {{todayTab === 'heritage' ? 'active' : ''}}"
        data-tab="heritage"
        bindtap="onTodayTab"
      >
        <text>{{i18n.todayHeritage}}</text>
      </view>
    </view>
  </view>

  <scroll-view scroll-x class="recommend-scroll" enable-flex wx:if="{{recommendCards.length}}">
    <view class="recommend-row">
      <view
        wx:for="{{recommendCards}}"
        wx:key="id"
        class="recommend-card tap-active"
        data-id="{{item.targetId}}"
        data-type="{{item.type}}"
        bindtap="goRecommend"
      >
        <image class="recommend-cover" src="{{item.cover}}" mode="aspectFill" lazy-load="{{false}}" />
        <view class="recommend-body">
          <text class="recommend-name title-serif">{{item.title}}</text>
          <text class="recommend-excerpt ellipsis-2">{{item.excerpt}}</text>
        </view>
      </view>
    </view>
  </scroll-view>

  <view class="home-section" wx:if="{{representativeHeritages.length}}">
    <view class="home-section-head">
      <view class="title-bar">
        <view class="title-bar-mark"></view>
        <text class="home-section-title title-serif">{{i18n.representativeTitle}}</text>
      </view>
      <text class="home-section-sub">{{representativeSubtitle}}</text>
    </view>
    <scroll-view scroll-x class="highlight-scroll" enable-flex>
      <view class="highlight-row">
        <view
          wx:for="{{representativeHeritages}}"
          wx:key="id"
          class="highlight-card tap-active"
          data-id="{{item.id}}"
          bindtap="goHeritageDetail"
        >
          <image class="highlight-cover" src="{{item.cover}}" mode="aspectFill" lazy-load="{{false}}" />
          <view class="highlight-body">
            <text class="highlight-tag">{{item.category}}</text>
            <text class="highlight-name title-serif ellipsis">{{item.name}}</text>
            <text class="highlight-summary ellipsis-2">{{item.summary}}</text>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>

  <view class="home-section" wx:if="{{cityInheritors.length}}">
    <view class="home-section-head-row">
      <view class="title-bar">
        <view class="title-bar-mark"></view>
        <text class="home-section-title title-serif">{{i18n.inheritorsTitle}}</text>
      </view>
      <text class="link-more tap-active" bindtap="goHeritageTab">{{i18n.viewMoreHeritage}} ›</text>
    </view>
    <view class="inheritor-grid">
      <view
        wx:for="{{cityInheritors}}"
        wx:key="id"
        class="inheritor-card tap-active"
        data-id="{{item.heritageId}}"
        bindtap="goHeritageDetail"
      >
        <image class="inheritor-avatar" src="{{item.cover}}" mode="aspectFill" lazy-load="{{false}}" />
        <text class="inheritor-name ellipsis">{{item.name}}</text>
        <text class="inheritor-heritage ellipsis">{{item.heritageName}}</text>
        <text class="inheritor-tag ellipsis">{{item.level}}</text>
      </view>
    </view>
  </view>
  </view>
</view>
<guide-mascot label="{{i18n.mascotLabel}}" bind:open="goAiGuide" />
