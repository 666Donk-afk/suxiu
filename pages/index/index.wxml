<view class="page page-fade-in safe-bottom">
  <view class="nav-header" style="padding-top: {{navPaddingTop}}px;">
    <view class="nav-inner">
      <view class="brand">
        <image class="logo-img nav-logo" src="/images/brand/logo.png" mode="aspectFit" />
        <text class="brand-name title-serif">{{i18n.appName}}</text>
      </view>
      <view class="search-entry tap-active" bindtap="goSearch">
        <text class="search-icon">⌕</text>
        <text class="search-placeholder">{{i18n.searchPlaceholder}}</text>
      </view>
    </view>
  </view>

  <view class="main-content" style="padding-top: {{mainPaddingTop}}px;">
    <swiper class="banner-swiper" autoplay circular interval="4000" indicator-dots indicator-color="rgba(255,255,255,0.4)" indicator-active-color="#FFFFFF">
      <swiper-item wx:for="{{banners}}" wx:key="id">
        <view class="banner-item">
          <image class="banner-img" src="{{item.image}}" mode="aspectFill" lazy-load />
          <view class="banner-mask"></view>
          <text class="banner-title title-serif">{{item.title}}</text>
        </view>
      </swiper-item>
    </swiper>

    <view class="section">
      <view class="section-header">
        <text class="section-title">{{personalized ? i18n.forYou + ' · ' + i18n.hotCities : i18n.hotCities}}</text>
        <text class="section-more">{{i18n.swipeHint}}</text>
      </view>
      <scroll-view scroll-x class="city-scroll" enable-flex>
        <view class="city-list">
          <view
            wx:for="{{hotCities}}"
            wx:key="id"
            class="city-card tap-active"
            data-id="{{item.id}}"
            bindtap="goCityDetail"
          >
            <image class="city-cover" src="{{item.cover}}" mode="aspectFill" lazy-load />
            <view class="city-info">
              <text class="city-name title-serif">{{item.name}}</text>
              <text class="city-count">{{item.heritageCount}} {{i18n.heritageUnit}}</text>
            </view>
          </view>
        </view>
      </scroll-view>
    </view>

    <view class="section travel-section" wx:if="{{travelRoutes.length}}">
      <view class="section-head">
        <text class="section-title title-serif">{{i18n.travelTitle}}</text>
        <text class="section-sub">{{i18n.travelSubtitle}}</text>
      </view>
      <view class="travel-route-list">
        <view
          wx:for="{{travelRoutes}}"
          wx:key="id"
          class="travel-route-card tap-active"
          data-id="{{item.heritageId}}"
          bindtap="goTravelRoute"
        >
          <image class="travel-route-cover" src="{{item.cover}}" mode="aspectFill" lazy-load />
          <view class="travel-route-body">
            <text class="travel-route-title title-serif ellipsis">{{item.routeTitle}}</text>
            <text class="travel-route-desc ellipsis">{{item.routeDesc}}</text>
            <view class="travel-route-action">
              <view class="route-pin"></view>
              <text class="route-link">{{i18n.exploreRoute}}</text>
            </view>
          </view>
          <text class="travel-route-arrow">›</text>
        </view>
      </view>
    </view>

    <view class="section-divider" wx:if="{{travelRoutes.length && categories.length}}"></view>

    <view class="section category-section" wx:if="{{categories.length}}">
      <text class="section-title title-serif">{{i18n.categoryTitle}}</text>
      <view class="category-grid">
        <view
          wx:for="{{categories}}"
          wx:key="key"
          class="category-item tap-active"
          data-key="{{item.key}}"
          bindtap="goCategory"
        >
          <view class="category-icon-box">
            <view class="category-icon-circle">
              <text class="category-icon">{{item.icon}}</text>
            </view>
          </view>
          <text class="category-label">{{item.label}}</text>
        </view>
      </view>
    </view>

    <view class="section heritage-section">
      <view class="section-header-bar">
        <text class="section-bar-title section-bar-title--inline">{{personalized ? i18n.forYou + ' · ' + i18n.hotHeritages : i18n.hotHeritages}}</text>
        <text class="section-count" wx:if="{{hotHeritages.length}}">{{hotHeritages.length}} {{i18n.itemUnit}}</text>
      </view>
      <view class="heritage-list">
        <heritage-card
          wx:for="{{hotHeritages}}"
          wx:key="id"
          item="{{item}}"
          like-count="{{item.likeCount}}"
          favorited="{{item.favorited}}"
          bind:favorite="onFavorite"
        />
      </view>
    </view>
  </view>

  <!-- AI 非遗助手入口 -->
  <guide-mascot label="{{i18n.mascotLabel}}" bind:open="goAiGuide" />
</view>
