@import '../../styles/v0-theme.wxss';

.page {
  min-height: 100vh;
}

.v0-header {
  padding-bottom: 24rpx;
}

.header-top-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.v0-header .location-row {
  flex-shrink: 0;
  max-width: 38%;
  padding: 0;
}

.v0-header .location-text {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.v0-header .v0-search {
  flex: 1;
  min-width: 0;
  margin: 0;
  padding: 18rpx 24rpx;
}

.v0-header .v0-search-placeholder {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 城市相关区块 */
.home-section {
  margin-bottom: 36rpx;
}

.home-section-head {
  padding: 0 32rpx;
  margin-bottom: 24rpx;
}

.home-section-head-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx;
  margin-bottom: 24rpx;
}

.home-section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--color-text);
  letter-spacing: 2rpx;
}

.home-section-sub {
  display: block;
  padding-left: 20rpx;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.link-more {
  font-size: 24rpx;
  color: var(--color-primary);
  flex-shrink: 0;
  padding-left: 16rpx;
}

.highlight-scroll {
  white-space: nowrap;
  padding: 0 32rpx;
}

.highlight-row {
  display: inline-flex;
  gap: 24rpx;
}

.highlight-card {
  display: inline-flex;
  flex-direction: column;
  width: 280rpx;
  background: var(--color-card);
  border-radius: var(--radius-lg);
  border: 1rpx solid var(--color-border);
  overflow: hidden;
  box-shadow: var(--shadow-card);
  vertical-align: top;
  white-space: normal;
}

.highlight-cover {
  width: 280rpx;
  height: 168rpx;
}

.highlight-body {
  padding: 20rpx;
}

.highlight-tag {
  display: inline-block;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  margin-bottom: 10rpx;
  color: var(--color-primary);
  background: var(--color-tag-bg);
  border-radius: 6rpx;
  border: 1rpx solid rgba(158, 43, 37, 0.15);
}

.highlight-name {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
  color: var(--color-text);
}

.highlight-summary {
  font-size: 22rpx;
  color: var(--color-text-body);
  line-height: 1.6;
}

.inheritor-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 0 24rpx;
}

.inheritor-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 25%;
  padding: 0 8rpx 16rpx;
  box-sizing: border-box;
}

.inheritor-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 3rpx solid var(--color-card);
  box-shadow: var(--shadow-soft);
  background: var(--color-bg-cream);
}

.inheritor-name {
  margin-top: 10rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: var(--color-text);
  text-align: center;
  width: 100%;
}

.inheritor-heritage {
  margin-top: 4rpx;
  font-size: 20rpx;
  color: var(--color-text-secondary);
  text-align: center;
  width: 100%;
}

.inheritor-tag {
  margin-top: 6rpx;
  font-size: 18rpx;
  color: var(--color-primary);
  background: var(--color-tag-bg);
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
  max-width: 100%;
  text-align: center;
}
