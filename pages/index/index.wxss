.page {
  min-height: 100vh;
  background: var(--color-bg);
}

.nav-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: linear-gradient(180deg, #A0301F 0%, #B34D2E 100%);
}

.nav-inner {
  padding: 16rpx 32rpx 24rpx;
}

.brand {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.nav-logo {
  width: 52rpx;
  height: 52rpx;
  margin-right: 12rpx;
}

.brand-name {
  font-size: 40rpx;
  color: #fff;
}

.search-entry {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 999rpx;
  padding: 18rpx 28rpx;
}

.search-icon {
  font-size: 32rpx;
  color: #A0301F;
  margin-right: 12rpx;
}

.search-placeholder {
  font-size: 26rpx;
  color: #8B7D6B;
}

.main-content {
  box-sizing: border-box;
}

.banner-swiper {
  height: 360rpx;
  margin: 16rpx 32rpx 40rpx;
  border-radius: 24rpx;
  overflow: hidden;
}

.banner-swiper swiper-item {
  height: 100%;
}

.banner-item {
  position: relative;
  width: 100%;
  height: 100%;
  border-radius: 24rpx;
  overflow: hidden;
}

.banner-img {
  display: block;
  width: 100%;
  height: 100%;
}

.banner-mask {
  position: absolute;
  inset: 0;
  background: linear-gradient(transparent 40%, rgba(160, 48, 31, 0.6));
}

.banner-title {
  position: absolute;
  left: 32rpx;
  bottom: 28rpx;
  color: #fff;
  font-size: 32rpx;
}

.section {
  padding: 0 32rpx 40rpx;
}

.city-scroll {
  white-space: nowrap;
}

.city-list {
  display: inline-flex;
  gap: 20rpx;
  padding-bottom: 8rpx;
}

.city-card {
  display: inline-flex;
  flex-direction: column;
  width: 220rpx;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 24rpx rgba(160, 48, 31, 0.06);
}

.city-cover {
  width: 220rpx;
  height: 160rpx;
  background: #F0EBE3;
}

.city-info {
  padding: 16rpx;
}

.city-name {
  font-size: 28rpx;
  display: block;
}

.city-count {
  font-size: 22rpx;
  color: #8B7D6B;
  margin-top: 4rpx;
}

.section-sub {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-muted);
  margin-top: 6rpx;
}

.travel-section .section-head {
  margin-bottom: var(--spacing-section-head-gap, 72rpx);
}

.travel-route-list {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.travel-route-card {
  display: flex;
  align-items: center;
  background: var(--color-card, #fff);
  border-radius: var(--radius-lg, 24rpx);
  padding: 24rpx;
  box-shadow: var(--shadow-card);
}

.travel-route-cover {
  width: 160rpx;
  height: 120rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  background: var(--color-bg-paper);
}

.travel-route-body {
  flex: 1;
  margin: 0 20rpx;
  min-width: 0;
}

.travel-route-title {
  display: block;
  font-size: 30rpx;
}

.travel-route-desc {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-muted);
  margin-top: 8rpx;
}

.travel-route-action {
  display: flex;
  align-items: center;
  margin-top: 12rpx;
}

.route-pin {
  width: 20rpx;
  height: 20rpx;
  margin-right: 8rpx;
  border-radius: 50%;
  background: var(--color-primary);
  position: relative;
  flex-shrink: 0;
}

.route-pin::after {
  content: '';
  position: absolute;
  left: 50%;
  top: 50%;
  width: 8rpx;
  height: 8rpx;
  margin: -4rpx 0 0 -4rpx;
  border-radius: 50%;
  background: #fff;
}

.route-link {
  font-size: 24rpx;
  color: var(--color-primary);
}

.travel-route-arrow {
  font-size: 40rpx;
  color: var(--color-text-muted);
  flex-shrink: 0;
  line-height: 1;
}

.section-divider {
  height: 1rpx;
  background: var(--color-divider);
  margin: 0 32rpx 40rpx;
}

.category-section .section-title {
  display: block;
  margin-bottom: var(--spacing-section-head-gap, 72rpx);
}

.category-grid {
  display: flex;
  flex-wrap: wrap;
}

.category-item {
  width: 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 32rpx;
}

.category-icon-box {
  width: 120rpx;
  height: 120rpx;
  background: var(--color-card, #fff);
  border-radius: 20rpx;
  box-shadow: var(--shadow-card);
  display: flex;
  align-items: center;
  justify-content: center;
}

.category-icon-circle {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: var(--color-tag-bg);
  display: flex;
  align-items: center;
  justify-content: center;
}

.category-icon {
  color: var(--color-primary);
  font-size: 32rpx;
  line-height: 1;
}

.category-label {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: var(--color-text);
  text-align: center;
  padding: 0 8rpx;
}
