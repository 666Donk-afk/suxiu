.page {
  min-height: 100vh;
  background: var(--color-bg);
}

.nav-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: linear-gradient(180deg, #A0301F 0%, #B34D2E 100%);
}

.nav-inner {
  padding: 16rpx 32rpx 24rpx;
}

.brand {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.nav-logo {
  width: 52rpx;
  height: 52rpx;
  margin-right: 12rpx;
}

.brand-name {
  font-size: 40rpx;
  color: #fff;
}

.search-entry {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 999rpx;
  padding: 18rpx 28rpx;
}

.search-icon {
  font-size: 32rpx;
  color: #A0301F;
  margin-right: 12rpx;
}

.search-placeholder {
  font-size: 26rpx;
  color: #8B7D6B;
}

.main-content {
  box-sizing: border-box;
}

.banner-swiper {
  height: 360rpx;
  margin: 16rpx 32rpx 40rpx;
  border-radius: 24rpx;
  overflow: hidden;
}

.banner-swiper swiper-item {
  height: 100%;
}

.banner-item {
  position: relative;
  width: 100%;
  height: 100%;
  border-radius: 24rpx;
  overflow: hidden;
}

.banner-img {
  display: block;
  width: 100%;
  height: 100%;
}

.banner-mask {
  position: absolute;
  inset: 0;
  background: linear-gradient(transparent 40%, rgba(160, 48, 31, 0.6));
}

.banner-title {
  position: absolute;
  left: 32rpx;
  bottom: 28rpx;
  color: #fff;
  font-size: 32rpx;
}

.section {
  padding: 0 32rpx 40rpx;
}

.city-scroll {
  white-space: nowrap;
}

.city-list {
  display: inline-flex;
  gap: 20rpx;
  padding-bottom: 8rpx;
}

.city-card {
  display: inline-flex;
  flex-direction: column;
  width: 220rpx;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 24rpx rgba(160, 48, 31, 0.06);
}

.city-cover {
  width: 220rpx;
  height: 160rpx;
  background: #F0EBE3;
}

.city-info {
  padding: 16rpx;
}

.city-name {
  font-size: 28rpx;
  display: block;
}

.city-count {
  font-size: 22rpx;
  color: #8B7D6B;
  margin-top: 4rpx;
}

.heritage-list {
  margin-top: 8rpx;
}

.section-sub {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-muted);
  margin-top: 6rpx;
}

.travel-scroll {
  white-space: nowrap;
}

.travel-list {
  display: inline-flex;
  gap: 20rpx;
  padding-bottom: 8rpx;
}

.travel-card {
  display: inline-flex;
  flex-direction: column;
  width: 280rpx;
  background: #fff;
  border-radius: var(--radius-md);
  overflow: hidden;
  box-shadow: var(--shadow-card);
}

.travel-cover {
  width: 280rpx;
  height: 160rpx;
  background: var(--color-bg-paper);
}

.travel-info {
  padding: 16rpx;
}

.travel-name {
  display: block;
  font-size: 28rpx;
}

.travel-city {
  display: block;
  font-size: 22rpx;
  color: var(--color-primary);
  margin-top: 4rpx;
}

.travel-desc {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-muted);
  margin-top: 8rpx;
  line-height: 1.4;
}
