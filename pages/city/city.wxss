.page {
  min-height: 100vh;
  background: transparent;
  padding-bottom: 40rpx;
}

.search-bar {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  background: #A0301F;
  gap: 16rpx;
}

.search-input-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 999rpx;
  padding: 16rpx 24rpx;
}

.search-icon {
  color: #A0301F;
  margin-right: 12rpx;
  font-size: 28rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
}

.placeholder {
  color: #8B7D6B;
}

.search-btn {
  color: #fff;
  font-size: 28rpx;
  padding: 16rpx 8rpx;
}

.suggestions {
  background: #fff;
  margin: 0 32rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.06);
  overflow: hidden;
}

.suggestion-item {
  display: flex;
  align-items: center;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid #F0EBE3;
  font-size: 28rpx;
}

.sug-type {
  font-size: 22rpx;
  color: #A0301F;
  background: #FDECEC;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-right: 16rpx;
}

.sug-city {
  margin-left: auto;
  font-size: 24rpx;
  color: #8B7D6B;
}

.history-section {
  padding: 24rpx 32rpx;
}

.history-label {
  font-size: 26rpx;
  color: #8B7D6B;
  margin-bottom: 16rpx;
  display: block;
}

.history-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.history-tag {
  padding: 10rpx 24rpx;
  background: #fff;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: #8B7D6B;
}

.section {
  padding: 32rpx;
}

.hot-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
  margin-top: 20rpx;
}

.hot-item {
  text-align: center;
}

.hot-cover {
  width: 100%;
  height: 140rpx;
  border-radius: 16rpx;
  background: #F0EBE3;
}

.hot-name {
  font-size: 26rpx;
  margin-top: 12rpx;
  display: block;
}

.index-list {
  margin-top: 16rpx;
}

.index-group {
  margin-bottom: 24rpx;
}

.index-letter {
  font-size: 28rpx;
  font-weight: 700;
  color: #A0301F;
  margin-bottom: 12rpx;
  display: block;
}

.index-city {
  display: flex;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #E8E0D0;
  font-size: 30rpx;
}

.index-count {
  color: #8B7D6B;
  font-size: 24rpx;
}

.side-index {
  position: fixed;
  right: 8rpx;
  top: 50%;
  transform: translateY(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  z-index: 10;
}

.side-letter {
  font-size: 20rpx;
  color: #A0301F;
  padding: 4rpx 8rpx;
}
