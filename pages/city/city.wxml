<view class="page city-page page-fade-in safe-bottom">
  <view class="search-bar">
    <view class="current-city">
      <image class="location-pin" src="/images/icons/location-pin.png" mode="aspectFit" />
      <text class="current-city-text">{{displayCity}}</text>
    </view>
    <view class="search-input-wrap">
      <text class="search-icon">⌕</text>
      <input
        class="search-input"
        placeholder="{{i18n.searchPlaceholder}}"
        placeholder-class="placeholder"
        value="{{keyword}}"
        bindinput="onInput"
        confirm-type="search"
        bindconfirm="onSearch"
      />
    </view>
    <view class="search-btn tap-active" bindtap="onSearch">{{i18n.search}}</view>
  </view>

  <view class="suggestions" wx:if="{{showSuggestions && suggestions.length}}">
    <view
      wx:for="{{suggestions}}"
      wx:key="text"
      class="suggestion-item tap-active"
      data-type="{{item.type}}"
      data-id="{{item.id}}"
      data-text="{{item.text}}"
      bindtap="onSuggestionTap"
    >
      <text class="sug-type">{{item.type === 'city' ? i18n.cityType : i18n.heritageType}}</text>
      <text>{{item.text}}</text>
      <text wx:if="{{item.city}}" class="sug-city">{{item.city}}</text>
    </view>
  </view>

  <view class="history-section" wx:if="{{searchHistory.length && !showSuggestions}}">
    <text class="history-label">{{i18n.searchHistory}}</text>
    <view class="history-tags">
      <text
        wx:for="{{searchHistory}}"
        wx:key="*this"
        class="history-tag tap-active"
        data-keyword="{{item}}"
        bindtap="onHistoryTap"
      >{{item}}</text>
    </view>
  </view>

  <view class="section">
    <text class="section-title">{{i18n.hotCities}}</text>
    <scroll-view scroll-x class="hot-scroll" enable-flex enhanced show-scrollbar="{{false}}">
      <view class="hot-scroll-inner">
        <view
          wx:for="{{hotCityColumns}}"
          wx:key="index"
          class="hot-column"
        >
          <view
            wx:for="{{item}}"
            wx:for-item="city"
            wx:key="id"
            class="hot-item tap-active"
            data-id="{{city.id}}"
            bindtap="goCityDetail"
          >
            <image class="hot-cover" src="{{city.cover}}" mode="aspectFill" lazy-load />
            <text class="hot-name title-serif">{{city.name}}</text>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>

  <view class="section section-index">
    <text class="section-title">{{i18n.cityIndex}}</text>
    <view class="locate-row tap-active" bindtap="locateCurrentCity">
      <image class="locate-icon" src="/images/icons/location-pin.png" mode="aspectFit" />
      <text class="locate-text">{{i18n.locateCurrentCity}}</text>
    </view>
    <view class="index-list">
      <block wx:for="{{indexGroups}}" wx:key="letter">
        <view class="index-group" id="{{item.letter === '#' ? 'letter-sharp' : 'letter-' + item.letter}}">
          <text class="index-letter">{{item.letter}}</text>
          <view
            wx:for="{{item.cities}}"
            wx:for-item="city"
            wx:key="id"
            id="city-{{city.id}}"
            class="index-city tap-active {{highlightCityId === city.id ? 'active' : ''}}"
            data-id="{{city.id}}"
            bindtap="goCityDetail"
          >
            <text>{{city.name}}</text>
          </view>
        </view>
      </block>
    </view>
  </view>
</view>
<view class="side-index" wx:if="{{indexLetters.length && !showSuggestions}}">
  <view
    wx:for="{{indexLetters}}"
    wx:key="*this"
    class="side-letter tap-active {{activeIndexLetter === item ? 'active' : ''}}"
    data-letter="{{item}}"
    bindtap="scrollToLetter"
  >
    <text class="side-letter-text">{{item}}</text>
  </view>
</view>
