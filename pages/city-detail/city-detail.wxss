.page {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

.hero {
  position: relative;
  height: 450rpx;
}

.hero-img {
  width: 100%;
  height: 100%;
}

.hero-mask {
  position: absolute;
  inset: 0;
  background: linear-gradient(transparent 30%, rgba(0,0,0,0.55));
}

.hero-info {
  position: absolute;
  left: 32rpx;
  bottom: 80rpx;
}

.hero-name {
  font-size: 48rpx;
  color: #fff;
  display: block;
}

.hero-count {
  font-size: 26rpx;
  color: rgba(255,255,255,0.85);
  margin-top: 8rpx;
}

.content-card {
  margin-top: -60rpx;
  background: var(--color-bg-paper);
  border-radius: 40rpx 40rpx 0 0;
  padding: 40rpx 32rpx;
  position: relative;
  z-index: 1;
}

.desc-section {
  margin-bottom: var(--spacing-card-gap, 48rpx);
}

.intro-panel {
  background: var(--color-card, #FFFFFF);
  border-radius: var(--radius-lg, 24rpx);
  box-shadow: var(--shadow-card, 0 4rpx 24rpx rgba(160, 48, 31, 0.06));
  padding: 28rpx 32rpx;
}

.desc-text {
  font-size: 28rpx;
  color: #8B7D6B;
  line-height: 1.7;
  text-align: justify;
}

.heritage-section {
  margin-top: 0;
}

.heritage-item {
  display: flex;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.item-cover {
  width: 180rpx;
  height: 180rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
  background: #F0EBE3;
}

.item-info {
  flex: 1;
  margin-left: 20rpx;
  min-width: 0;
}

.item-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 12rpx;
}

.item-name {
  font-size: 32rpx;
  flex: 1;
}

.item-level {
  margin: 8rpx 0;
  display: inline-block;
}

.item-summary {
  font-size: 24rpx;
  color: #8E8E8E;
  line-height: 1.5;
}

.load-more {
  text-align: center;
  padding: 24rpx;
  font-size: 24rpx;
  color: #8B7D6B;
}
