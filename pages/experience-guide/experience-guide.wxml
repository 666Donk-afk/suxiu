<view class="page experience-guide-page page-fade-in" wx:if="{{experience}}">
  <view class="hero">
    <image class="hero-cover" src="{{experience.cover}}" mode="aspectFill" />
    <view class="hero-mask"></view>
    <view class="hero-info">
      <text class="hero-title title-serif">{{experience.title}}</text>
      <text class="hero-location">{{experience.location}}</text>
    </view>
  </view>

  <view class="content">
    <view class="card intro-card">
      <text class="desc">{{experience.description}}</text>
      <view class="meta-row">
        <text class="meta-label">{{i18n.openTime}}</text>
        <text class="meta-value">{{experience.openTime}}</text>
      </view>
    </view>

    <view class="card guide-card">
      <text class="section-title title-serif">{{i18n.guideDesc}}</text>

      <block wx:if="{{experience.reservationType === 'qr'}}">
        <view class="platform-box" wx:if="{{experience.officialMiniProgram || experience.officialWebsite}}">
          <text class="platform-label">{{i18n.miniLabel}}</text>
          <text class="platform-name">{{experience.officialMiniProgram || experience.officialWebsite}}</text>
        </view>
        <view class="qr-wrap tap-active" bindtap="previewQr">
          <image class="qr-img" src="{{experience.qrCode}}" mode="aspectFit" show-menu-by-longpress />
        </view>
        <text class="hint-text">{{i18n.qrHint}}</text>
        <view class="preview-link tap-active" bindtap="previewQr">{{i18n.previewQr}}</view>
        <view class="copy-mini tap-active" wx:if="{{experience.qrTargetUrl}}" bindtap="onCopyQrUrl">{{i18n.copyLink}}</view>
        <view class="copy-mini tap-active open-article" wx:if="{{canOpenWeixinArticle}}" bindtap="openWeixinArticle">{{i18n.openArticle}}</view>
      </block>

      <block wx:elif="{{experience.reservationType === 'mini'}}">
        <view class="platform-box">
          <text class="platform-label">{{i18n.miniLabel}}</text>
          <text class="platform-name">{{experience.officialMiniProgram}}</text>
        </view>
        <text class="hint-text">{{i18n.miniHint}}</text>
        <view class="copy-mini tap-active" wx:if="{{experience.officialMiniProgram}}" bindtap="onCopyMini">{{i18n.copyInfo}}</view>
      </block>

      <block wx:elif="{{experience.reservationType === 'website'}}">
        <view class="platform-box">
          <text class="platform-label">{{i18n.miniLabel}}</text>
          <text class="platform-name ellipsis">{{experience.officialWebsite}}</text>
        </view>
        <text class="hint-text">{{i18n.websiteHint}}</text>
        <view class="copy-mini tap-active" bindtap="onCopyWebsite">{{i18n.copyInfo}}</view>
      </block>
    </view>

    <view class="card notice-card" wx:if="{{experience.notice}}">
      <text class="section-title title-serif">{{i18n.noticeTitle}}</text>
      <text class="notice-text">{{experience.notice}}</text>
    </view>
  </view>

  <view class="footer-bar safe-bottom">
    <view class="btn-outline tap-active" bindtap="onCopy">{{i18n.copyInfo}}</view>
    <view class="btn-primary tap-active" bindtap="goBack">{{i18n.backDetail}}</view>
  </view>
</view>
