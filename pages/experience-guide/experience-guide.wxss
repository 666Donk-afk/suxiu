.page {
  min-height: 100vh;
  background: var(--color-bg);
  padding-bottom: calc(env(safe-area-inset-bottom) + 140rpx);
}

.hero {
  position: relative;
  height: 400rpx;
}

.hero-cover {
  width: 100%;
  height: 100%;
}

.hero-mask {
  position: absolute;
  inset: 0;
  background: linear-gradient(transparent 40%, rgba(160, 48, 31, 0.55));
}

.hero-info {
  position: absolute;
  left: 32rpx;
  right: 32rpx;
  bottom: 32rpx;
}

.hero-title {
  display: block;
  font-size: 40rpx;
  color: #fff;
}

.hero-location {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-top: 8rpx;
}

.content {
  padding: 24rpx 32rpx;
}

.card {
  background: #fff;
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.desc {
  display: block;
  font-size: 28rpx;
  color: var(--color-text-secondary);
  line-height: 1.8;
  margin-bottom: 24rpx;
}

.meta-row {
  display: flex;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--color-divider);
}

.meta-label {
  font-size: 26rpx;
  color: var(--color-text-muted);
  margin-right: 16rpx;
}

.meta-value {
  font-size: 26rpx;
  color: var(--color-primary);
}

.section-title {
  display: block;
  font-size: 32rpx;
  margin-bottom: 24rpx;
  color: var(--color-text);
}

.qr-wrap {
  display: flex;
  justify-content: center;
  padding: 24rpx;
  background: var(--color-bg-paper);
  border-radius: var(--radius-md);
  margin-bottom: 20rpx;
}

.qr-img {
  width: 420rpx;
  height: 420rpx;
}

.hint-text {
  display: block;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.7;
  text-align: center;
}

.preview-link {
  text-align: center;
  font-size: 26rpx;
  color: var(--color-primary);
  margin-top: 16rpx;
}

.platform-box {
  background: var(--color-bg-cream);
  border-radius: var(--radius-md);
  padding: 28rpx;
  margin-bottom: 20rpx;
  border-left: 6rpx solid var(--color-primary);
}

.platform-label {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-muted);
  margin-bottom: 8rpx;
}

.platform-name {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-primary);
}

.copy-mini {
  text-align: center;
  margin-top: 20rpx;
  font-size: 26rpx;
  color: var(--color-primary);
}

.notice-text {
  display: block;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.8;
}

.footer-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  gap: 20rpx;
  padding: 20rpx 32rpx calc(env(safe-area-inset-bottom) + 20rpx);
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.btn-outline,
.btn-primary {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  border-radius: var(--radius-pill);
  font-size: 28rpx;
}

.btn-outline {
  background: var(--color-bg-cream);
  color: var(--color-text);
  border: 1rpx solid var(--color-divider);
}

.btn-primary {
  background: var(--color-primary);
  color: #fff;
}
