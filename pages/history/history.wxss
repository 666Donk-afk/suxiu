.page {
  min-height: 100vh;
  background: var(--color-bg);
  padding: 24rpx 32rpx;
}

.toolbar {
  text-align: right;
  margin-bottom: 16rpx;
}

.clear {
  font-size: 26rpx;
  color: #A0301F;
}

.history-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  margin-bottom: 16rpx;
}

.cover {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  background: #F0EBE3;
}

.info {
  flex: 1;
  margin-left: 20rpx;
}

.name {
  font-size: 30rpx;
  display: block;
}

.meta {
  font-size: 24rpx;
  color: #8B7D6B;
  margin-top: 8rpx;
}

.remove {
  font-size: 40rpx;
  color: #ccc;
  padding: 0 16rpx;
}

.login-cta {
  margin-top: 32rpx;
  padding: 20rpx 56rpx;
  background: var(--color-primary);
  color: #fff;
  font-size: 28rpx;
  border-radius: var(--radius-pill);
}
