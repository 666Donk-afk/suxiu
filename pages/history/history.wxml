<view class="page page-fade-in safe-bottom">
  <view wx:if="{{isGuest}}" class="empty-wrap">
    <text class="empty-icon">📖</text>
    <text class="empty-text">{{i18n.guestTitle}}</text>
    <view class="login-cta tap-active" bindtap="goLogin">{{i18n.goLogin}}</view>
  </view>

  <block wx:else>
  <view wx:if="{{list.length}}" class="toolbar">
    <text class="clear tap-active" bindtap="onClear">{{i18n.clear}}</text>
  </view>

  <view wx:if="{{list.length}}" class="list">
    <view wx:for="{{list}}" wx:key="id" class="history-item card tap-active" data-id="{{item.id}}" bindtap="goDetail">
      <image class="cover" src="{{item.cover}}" mode="aspectFill" />
      <view class="info">
        <text class="name title-serif">{{item.name}}</text>
        <text class="meta">{{item.city}} · {{item.level}}</text>
      </view>
      <text class="remove tap-active" data-id="{{item.id}}" catchtap="onRemove">×</text>
    </view>
  </view>

  <view wx:else class="empty-wrap">
    <text class="empty-text">{{i18n.empty}}</text>
  </view>
  </block>
</view>
