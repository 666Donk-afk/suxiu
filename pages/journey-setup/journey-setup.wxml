<view class="journey-page page-fade-in">

  <view class="journey-bg">

    <view class="deco-ring ring-1"></view>

    <view class="deco-ring ring-2"></view>

    <view class="deco-mountain"></view>

  </view>



  <!-- Step 1 / 2 / 4：可滚动内容 -->

  <scroll-view

    wx:if="{{step !== 3}}"

    class="journey-scroll"

    scroll-y

    enhanced

    show-scrollbar="{{false}}"

  >

    <view class="top-bar safe-top">

      <view class="back-btn tap-active" wx:if="{{step > 1 && step <= 4}}" bindtap="onBack">

        <text class="back-icon">‹</text>

        <text>{{i18n.back}}</text>

      </view>

      <view class="back-placeholder" wx:else></view>

      <view class="skip-btn tap-active" wx:if="{{step <= 4}}" bindtap="onSkip">{{i18n.skip}}</view>

    </view>



    <view class="progress-wrap" wx:if="{{step <= 4}}">

      <text class="progress-label">{{i18n.progress}}</text>

      <view class="progress-track">

        <view class="progress-fill" style="width: {{step * 25}}%;"></view>

      </view>

    </view>



    <view class="step-body {{showContent ? 'visible' : ''}}" wx:if="{{step === 1}}">

      <view class="headline">

        <text class="step-title title-serif">{{i18n.step1Title}}</text>

        <text class="step-subtitle">{{i18n.step1Subtitle}}</text>

      </view>

      <view class="lang-list">

        <view

          wx:for="{{languages}}"

          wx:key="code"

          class="lang-card tap-active {{selectedLanguage === item.code ? 'selected' : ''}}"

          data-code="{{item.code}}"

          bindtap="onSelectLanguage"

        >

          <text class="flag">{{item.flag}}</text>

          <view class="lang-info">

            <text class="native">{{item.native}}</text>

            <text class="english">{{item.english}}</text>

          </view>

          <view class="check" wx:if="{{selectedLanguage === item.code}}">✓</view>

        </view>

      </view>

    </view>



    <view class="step-body step-map {{showContent ? 'visible' : ''}}" wx:if="{{step === 2}}">

      <view class="headline compact">

        <text class="step-title title-serif">{{i18n.step2Title}}</text>

        <text class="step-subtitle">{{i18n.step2Subtitle}}</text>

      </view>

      <view class="selected-banner" wx:if="{{selectedCity}}">

        <text class="banner-label">{{i18n.step2SelectedLabel}}</text>

        <text class="banner-city">📍 {{selectedCity}}</text>

      </view>

      <view class="selection-summary" wx:if="{{selectionSummary}}">

        <view class="summary-line">

          <text class="summary-key">{{i18n.step2Destination}}</text>

          <text class="summary-val">{{selectionSummary.city}}</text>

        </view>

        <view class="summary-line">

          <text class="summary-key">{{i18n.step2Province}}</text>

          <text class="summary-val">{{selectionSummary.province}}</text>

        </view>

        <view class="summary-line">

          <text class="summary-key">{{i18n.step2HeritageDirections}}</text>

          <text class="summary-val">{{selectionSummary.heritageDirections}}</text>

        </view>

      </view>

      <view class="map-stage" wx:if="{{mapView === 'china'}}">

        <text class="map-hint">{{i18n.step2TapMapHint}}</text>

        <china-map

          selectedCode="{{selectedProvinceCode}}"

          activeCode="{{activeProvinceCode}}"

          bind:provincechange="onProvinceMapChange"

        />

      </view>

      <view class="map-stage" wx:elif="{{mapView === 'province'}}">

        <view class="map-toolbar">

          <text class="map-hint">{{i18n.step2TapProvinceMapHint}}</text>

          <view class="back-china-btn tap-active" bindtap="onBackToChinaMap" aria-label="{{i18n.step2BackToChina}}">

            <image class="back-china-icon" src="/images/maps/china-map.png" mode="aspectFill" />

          </view>

        </view>

        <province-map

          provinceCode="{{activeProvinceCode}}"

          selectedCity="{{selectedCity}}"

          bind:citychange="onProvinceCityChange"

        />

      </view>

    </view>



    <view class="step-body {{showContent ? 'visible' : ''}}" wx:if="{{step === 4}}">

      <view class="headline">

        <text class="step-title title-serif">{{i18n.step4Title}}</text>

        <text class="step-subtitle">{{i18n.step4Subtitle}}</text>

      </view>

      <view class="option-list">

        <view

          wx:for="{{travelOptions}}"

          wx:key="key"

          class="option-card tap-active {{selectedTravel === item.key ? 'selected' : ''}}"

          data-key="{{item.key}}"

          bindtap="onSelectTravel"

        >

          <view class="radio {{selectedTravel === item.key ? 'checked' : ''}}"></view>

          <text class="option-label">{{item.label}}</text>

        </view>

      </view>

    </view>

  </scroll-view>



  <!-- Step 3：Canvas 必须在 scroll-view 外（微信原生组件限制） -->

  <view class="journey-step3" wx:if="{{step === 3}}">

    <view class="top-bar safe-top">

      <view class="back-btn tap-active" bindtap="onBack">

        <text class="back-icon">‹</text>

        <text>{{i18n.back}}</text>

      </view>

      <view class="skip-btn tap-active" bindtap="onSkip">{{i18n.skip}}</view>

    </view>



    <view class="progress-wrap">

      <text class="progress-label">{{i18n.progress}}</text>

      <view class="progress-track">

        <view class="progress-fill" style="width: {{step * 25}}%;"></view>

      </view>

    </view>



    <view class="step-body step-interest {{showContent ? 'visible' : ''}}">

      <view class="interest-headline">

        <text class="step-title title-serif">{{i18n.step3Title}}</text>

        <text class="step-subtitle">{{i18n.step3Subtitle}}</text>

        <view class="interest-meta">

          <text class="step-hint">{{i18n.step3Hint}}</text>

          <text class="interest-count" wx:if="{{selectedCategories.length > 0}}">{{i18n.step3SelectedText}}</text>

        </view>

      </view>

      <view class="interest-canvas-wrap">

        <canvas

          type="2d"

          id="interestCanvas"

          class="interest-canvas"

          disable-scroll="true"

          bindtouchstart="onInterestCanvasTouchStart"

          bindtouchend="onInterestCanvasTouchEnd"

          bindtouchcancel="onInterestCanvasTouchEnd"

        ></canvas>

      </view>

    </view>

  </view>



  <view class="footer footer-dual safe-bottom" wx:if="{{step === 2}}">

    <view class="secondary-btn tap-active" bindtap="onBack">{{i18n.step2PrevStep}}</view>

    <view class="primary-btn tap-active {{selectedCity ? '' : 'disabled'}}" bindtap="onNext">{{i18n.next}}</view>

  </view>

  <view class="footer safe-bottom" wx:elif="{{step === 3}}">

    <view class="primary-btn tap-active {{selectedCategories.length > 0 ? '' : 'disabled'}}" bindtap="onNext">{{i18n.step3NextLabel}}</view>

  </view>

  <view class="footer safe-bottom" wx:elif="{{step < 4}}">

    <view class="primary-btn tap-active" bindtap="onNext">{{i18n.next}}</view>

  </view>

  <view class="footer safe-bottom" wx:elif="{{step === 4}}">

    <view class="primary-btn tap-active glow" bindtap="onNext">{{i18n.startExplore}}</view>

  </view>



  <view class="sheet-mask" wx:if="{{showCitySheet}}" bindtap="onCloseCitySheet">

    <view class="city-sheet" catchtap="">

      <view class="sheet-handle"></view>

      <text class="sheet-title title-serif">{{sheetProvinceName}}</text>

      <text class="sheet-hint">{{i18n.step2TapCityCardHint}}</text>

      <scroll-view scroll-y class="city-card-scroll" enhanced show-scrollbar="{{false}}">

        <view class="city-card-grid">

          <view

            wx:for="{{sheetCityCards}}"

            wx:key="name"

            class="city-card tap-active {{selectedCity === item.name ? 'selected' : ''}}"

            data-name="{{item.name}}"

            bindtap="onPickCityCard"

          >

            <image class="city-card-cover" src="{{item.cover}}" mode="aspectFill" lazy-load />

            <view class="city-card-mask"></view>

            <text class="city-card-name">{{item.name}}</text>

          </view>

        </view>

      </scroll-view>

    </view>

  </view>



  <view class="modal-mask" wx:if="{{showExperienceModal}}" bindtap="onCloseExperienceModal">

    <view class="modal-card" catchtap="">

      <text class="modal-title title-serif">{{i18n.experienceModalTitle}}</text>

      <view class="modal-actions">

        <view class="modal-btn tap-active" data-value="yes" bindtap="onExperiencePrefer">{{i18n.experienceModalYes}}</view>

        <view class="modal-btn outline tap-active" data-value="no" bindtap="onExperiencePrefer">{{i18n.experienceModalNo}}</view>

      </view>

    </view>

  </view>

</view>


