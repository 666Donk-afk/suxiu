.lang-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF9F0 0%, #FFFFFF 50%, #FDF5E6 100%);
  position: relative;
  overflow: hidden;
}

.lang-bg {
  position: absolute;
  inset: 0;
  pointer-events: none;
}

.deco-ring {
  position: absolute;
  border-radius: 50%;
  border: 2rpx solid rgba(160, 48, 31, 0.08);
}

.ring-1 {
  width: 500rpx;
  height: 500rpx;
  top: -100rpx;
  right: -120rpx;
}

.ring-2 {
  width: 360rpx;
  height: 360rpx;
  bottom: 120rpx;
  left: -80rpx;
}

.lang-body {
  position: relative;
  z-index: 1;
  padding: calc(env(safe-area-inset-top) + 80rpx) 48rpx calc(env(safe-area-inset-bottom) + 48rpx);
  opacity: 0;
  transition: opacity 400ms ease;
}

.lang-body.visible {
  opacity: 1;
}

.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 56rpx;
}

.lang-logo {
  width: 100rpx;
  height: 100rpx;
  margin-bottom: 20rpx;
}

.app-name {
  font-size: 44rpx;
  color: var(--color-primary);
  letter-spacing: 6rpx;
}

.headline {
  text-align: center;
  margin-bottom: 48rpx;
}

.title {
  display: block;
  font-size: 40rpx;
  margin-bottom: 16rpx;
  letter-spacing: 2rpx;
}

.subtitle {
  display: block;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.7;
}

.lang-list {
  margin-bottom: 48rpx;
}

.lang-card {
  display: flex;
  align-items: center;
  padding: 32rpx 28rpx;
  background: var(--color-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-soft);
  margin-bottom: 20rpx;
  border: 3rpx solid transparent;
  transition: all 250ms ease;
}

.lang-card.selected {
  border-color: var(--color-primary);
  box-shadow: var(--shadow-card);
  transform: scale(1.02);
}

.lang-card:active {
  transform: scale(0.98);
}

.lang-card.selected:active {
  transform: scale(1);
}

.flag {
  font-size: 48rpx;
  margin-right: 24rpx;
}

.lang-info {
  flex: 1;
}

.native {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text);
}

.english {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-muted);
  margin-top: 6rpx;
}

.check {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: var(--color-primary);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}

.start-btn {
  width: 100%;
  padding: 28rpx 0;
  text-align: center;
  background: var(--color-primary);
  color: #fff;
  font-size: 30rpx;
  border-radius: var(--radius-pill);
  letter-spacing: 4rpx;
  box-shadow: 0 8rpx 24rpx rgba(160, 48, 31, 0.25);
}

.start-btn:active {
  transform: scale(0.96);
}
