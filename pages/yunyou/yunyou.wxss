@import '../../styles/v0-theme.wxss';

.section-label {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 20rpx;
}

.label-icon {
  color: var(--color-primary);
  font-size: 28rpx;
}

.ai-banner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 0 32rpx 28rpx;
  padding: 28rpx 32rpx;
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
}

.ai-banner-title {
  font-size: 30rpx;
  color: #fff;
  font-weight: 600;
}

.ai-banner-arrow {
  font-size: 40rpx;
  color: rgba(255, 255, 255, 0.9);
}

.city-scroll {
  white-space: nowrap;
}

.city-row {
  display: inline-flex;
  gap: 20rpx;
}

.city-card {
  display: inline-flex;
  flex-direction: column;
  width: 200rpx;
}

.city-cover {
  width: 200rpx;
  height: 140rpx;
  border-radius: var(--radius-md);
  background: var(--color-bg-cream);
}

.city-name {
  font-size: 26rpx;
  margin-top: 10rpx;
  text-align: center;
}

.city-index-link {
  display: block;
  text-align: center;
  margin-top: 20rpx;
  font-size: 26rpx;
  color: var(--color-primary);
}

.route-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.route-card {
  display: flex;
  align-items: center;
  background: var(--color-card);
  border-radius: var(--radius-lg);
  padding: 20rpx;
  box-shadow: var(--shadow-card);
}

.route-cover {
  width: 140rpx;
  height: 110rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.route-body {
  flex: 1;
  margin: 0 16rpx;
  min-width: 0;
}

.route-title {
  display: block;
  font-size: 28rpx;
}

.route-desc {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-muted);
  margin: 6rpx 0;
}

.route-link {
  font-size: 22rpx;
  color: var(--color-primary);
}

.route-arrow {
  font-size: 36rpx;
  color: var(--color-text-muted);
}
