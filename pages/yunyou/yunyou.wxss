.yunyou-header {
  padding-bottom: 0;
}

.yunyou-header .page-title {
  line-height: 1.2;
}

.section-label {
  display: flex;
  align-items: flex-end;
  gap: 0;
  margin-bottom: 20rpx;
}

.section-label .section-title {
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1;
  margin-bottom: 0;
  display: block;
}

.section-label .city-index-link {
  margin-left: 8rpx;
  margin-bottom: 0;
  font-size: 24rpx;
  color: var(--color-primary);
  line-height: 1;
  flex-shrink: 0;
  display: block;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.2;
  margin-bottom: 0;
}

.ai-banner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 24rpx 32rpx 28rpx;
  padding: 28rpx 32rpx;
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
}

.ai-banner-title {
  font-size: 30rpx;
  color: #fff;
  font-weight: 600;
}

.ai-banner-arrow {
  font-size: 40rpx;
  color: rgba(255, 255, 255, 0.9);
}

.city-scroll {
  white-space: nowrap;
}

.city-row {
  display: inline-flex;
  gap: 20rpx;
}

.city-card {
  display: inline-flex;
  flex-direction: column;
  width: 200rpx;
}

.city-cover {
  width: 200rpx;
  height: 140rpx;
  border-radius: var(--radius-md);
  background: var(--color-bg-cream);
}

.city-name {
  font-size: 26rpx;
  margin-top: 10rpx;
  text-align: center;
}

.route-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.route-card {
  display: flex;
  align-items: center;
  background: var(--color-card);
  border-radius: var(--radius-lg);
  padding: 20rpx;
  box-shadow: var(--shadow-card);
}

.route-cover {
  width: 140rpx;
  height: 110rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.route-body {
  flex: 1;
  margin: 0 16rpx;
  min-width: 0;
}

.route-title {
  display: block;
  font-size: 28rpx;
}

.route-desc {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-muted);
  margin: 6rpx 0;
}

.route-link {
  font-size: 22rpx;
  color: var(--color-primary);
}

.route-arrow {
  font-size: 36rpx;
  color: var(--color-text-muted);
}
