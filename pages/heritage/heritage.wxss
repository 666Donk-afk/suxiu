.header-deco {
  font-size: 48rpx;
  color: var(--color-primary);
  opacity: 0.35;
}

.filter-scroll {
  margin: 0 32rpx 24rpx;
  white-space: nowrap;
}

.filter-row {
  display: inline-flex;
  gap: 16rpx;
}

.filter-pill {
  display: inline-flex;
  padding: 12rpx 28rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  background: var(--color-card);
  color: var(--color-text-secondary);
  border: 1rpx solid var(--color-border);
  box-shadow: var(--shadow-soft);
}

.filter-pill.active {
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
  color: #fff;
  border-color: transparent;
}

.section-label {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 20rpx;
}

.section-label-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-label-row .section-label {
  margin-bottom: 0;
}

.label-icon {
  color: var(--color-primary);
  font-size: 24rpx;
}

.link-more {
  font-size: 24rpx;
  color: var(--color-text-muted);
}

.featured-card {
  position: relative;
  height: 360rpx;
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: var(--shadow-card);
}

.featured-cover {
  width: 100%;
  height: 100%;
}

.featured-mask {
  position: absolute;
  inset: 0;
  background: linear-gradient(transparent 30%, rgba(0, 0, 0, 0.65));
}

.play-btn {
  position: absolute;
  left: 50%;
  top: 42%;
  transform: translate(-50%, -50%);
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.85);
  color: var(--color-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  padding-left: 6rpx;
}

.featured-info {
  position: absolute;
  left: 24rpx;
  right: 24rpx;
  bottom: 24rpx;
}

.featured-tag {
  display: inline-block;
  padding: 4rpx 14rpx;
  background: var(--color-primary);
  color: #fff;
  font-size: 20rpx;
  border-radius: 6rpx;
  margin-bottom: 10rpx;
}

.featured-name {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
}

.featured-desc {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.88);
  line-height: 1.5;
}

.featured-duration {
  position: absolute;
  right: 24rpx;
  bottom: 24rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.9);
}

.inheritor-scroll {
  white-space: nowrap;
}

.inheritor-row {
  display: inline-flex;
  gap: 24rpx;
  padding-bottom: 8rpx;
}

.inheritor-card {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  width: 180rpx;
}

.inheritor-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid var(--color-card);
  box-shadow: var(--shadow-soft);
}

.inheritor-name {
  margin-top: 12rpx;
  font-size: 26rpx;
}

.inheritor-tag {
  margin-top: 6rpx;
  font-size: 20rpx;
  color: var(--color-primary);
  background: var(--color-tag-bg);
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.encyclopedia-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.ency-card {
  display: flex;
  background: var(--color-card);
  border-radius: var(--radius-lg);
  padding: 20rpx;
  box-shadow: var(--shadow-card);
}

.ency-cover {
  width: 180rpx;
  height: 180rpx;
  border-radius: var(--radius-sm);
  flex-shrink: 0;
}

.ency-body {
  flex: 1;
  margin-left: 20rpx;
  min-width: 0;
}

.ency-tag {
  font-size: 22rpx;
  color: var(--color-primary);
}

.ency-name {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  margin: 6rpx 0;
}

.ency-level {
  display: inline-block;
  font-size: 20rpx;
  color: var(--color-primary);
  border: 1rpx solid var(--color-primary-light);
  padding: 2rpx 12rpx;
  border-radius: 6rpx;
  margin-bottom: 8rpx;
}

.ency-summary {
  font-size: 24rpx;
  color: var(--color-text-body);
  line-height: 1.5;
}
