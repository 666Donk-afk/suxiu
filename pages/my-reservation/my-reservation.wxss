.page {
  min-height: 100vh;
  background: transparent;
  padding: 24rpx 32rpx 40rpx;
}

.page-head {
  margin-bottom: 32rpx;
}

.page-title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: var(--color-text);
  letter-spacing: 2rpx;
}

.page-sub {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.section {
  margin-bottom: 36rpx;
}

.section-label {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 20rpx;
}

.label-icon {
  color: var(--color-primary);
  font-size: 28rpx;
}

.record-list,
.available-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.record-card {
  display: flex;
  align-items: center;
  padding: 20rpx;
}

.record-main {
  flex: 1;
  display: flex;
  align-items: center;
  min-width: 0;
}

.record-cover {
  width: 120rpx;
  height: 120rpx;
  border-radius: var(--radius-sm);
  flex-shrink: 0;
  background: var(--color-bg-cream);
}

.record-body {
  flex: 1;
  margin-left: 20rpx;
  min-width: 0;
}

.record-name {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
}

.record-meta {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: var(--color-text-muted);
}

.record-heritage {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--color-primary);
}

.record-remove {
  font-size: 24rpx;
  color: var(--color-primary);
  padding: 8rpx 12rpx;
  flex-shrink: 0;
}

.available-card {
  display: flex;
  padding: 20rpx;
}

.available-cover {
  width: 160rpx;
  height: 160rpx;
  border-radius: var(--radius-sm);
  flex-shrink: 0;
  background: var(--color-bg-cream);
}

.available-body {
  flex: 1;
  margin-left: 20rpx;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.available-name {
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.available-meta {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  margin-bottom: 8rpx;
}

.available-desc {
  font-size: 24rpx;
  color: var(--color-text-body);
  line-height: 1.6;
  flex: 1;
}

.available-action {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: var(--color-primary);
  font-weight: 700;
}

.empty-box {
  padding: 40rpx 24rpx;
  background: var(--color-card);
  border-radius: var(--radius-lg);
  border: 1rpx solid var(--color-border);
  text-align: center;
}

.empty-text {
  font-size: 26rpx;
  color: var(--color-text-muted);
  line-height: 1.6;
}
