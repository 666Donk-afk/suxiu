.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: var(--color-bg);
  box-sizing: border-box;
}

.nav-bar {
  flex-shrink: 0;
  background: linear-gradient(180deg, #A0301F 0%, #B34D2E 100%);
}

.nav-inner {
  display: flex;
  align-items: center;
  padding: 0 24rpx;
}

.nav-back {
  width: 64rpx;
  font-size: 52rpx;
  color: #fff;
  line-height: 1;
  font-weight: 300;
}

.nav-center {
  flex: 1;
  display: flex;
  align-items: center;
  min-width: 0;
  gap: 16rpx;
}

.nav-title {
  display: block;
  font-size: 34rpx;
  color: #fff;
}

.nav-sub {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 4rpx;
}

.nav-action {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.92);
  padding: 8rpx 12rpx;
}

.context-bar {
  flex-shrink: 0;
  padding: 12rpx 32rpx;
  background: var(--color-bg-cream);
  border-bottom: 1rpx solid var(--color-divider);
}

.context-text {
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

.chat-scroll {
  flex: 1;
  min-height: 0;
}

.chat-list {
  padding: 24rpx 24rpx 16rpx;
}

.typing-row {
  display: flex;
  align-items: flex-start;
  margin-bottom: 28rpx;
}

.typing-avatar-slot {
  flex-shrink: 0;
  margin-right: 16rpx;
}

.typing-bubble {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: var(--shadow-card);
}

.typing-text {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  margin-right: 12rpx;
}

.typing-dots {
  display: flex;
  gap: 8rpx;
}

.typing-dots .dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: var(--color-primary-light);
  animation: blink 1.2s infinite ease-in-out;
}

.typing-dots .dot:nth-child(2) { animation-delay: 0.2s; }
.typing-dots .dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes blink {
  0%, 80%, 100% { opacity: 0.3; transform: scale(0.85); }
  40% { opacity: 1; transform: scale(1); }
}

.chat-bottom {
  height: 24rpx;
}

.quick-bar {
  flex-shrink: 0;
  padding: 8rpx 0 12rpx;
  background: var(--color-bg);
}

.quick-scroll {
  white-space: nowrap;
  padding: 0 24rpx;
}

.quick-chip {
  display: inline-block;
  margin-right: 16rpx;
  padding: 14rpx 24rpx;
  font-size: 24rpx;
  color: var(--color-primary);
  background: var(--color-tag-bg);
  border-radius: var(--radius-pill);
  border: 1rpx solid rgba(160, 48, 31, 0.12);
}

.input-bar {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx 24rpx;
  background: #fff;
  border-top: 1rpx solid var(--color-divider);
  gap: 16rpx;
}

.chat-input {
  flex: 1;
  height: 76rpx;
  padding: 0 28rpx;
  background: var(--color-bg-cream);
  border-radius: var(--radius-pill);
  font-size: 28rpx;
}

.input-ph {
  color: var(--color-text-muted);
}

.send-btn {
  flex-shrink: 0;
  padding: 0 28rpx;
  height: 76rpx;
  line-height: 76rpx;
  border-radius: var(--radius-pill);
  font-size: 28rpx;
  color: #fff;
  background: #ccc;
  text-align: center;
}

.send-btn.active {
  background: linear-gradient(135deg, #A0301F, #B34D2E);
}
