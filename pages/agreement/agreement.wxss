.page {
  min-height: 100vh;
  padding: 32rpx;
  background: transparent;
}

.content {
  padding: 40rpx 32rpx;
}

.doc-title {
  display: block;
  font-size: 40rpx;
  text-align: center;
  margin-bottom: 40rpx;
  color: var(--color-primary);
}

.section {
  margin-bottom: 32rpx;
}

.section-heading {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
  color: var(--color-text);
}

.section-text {
  display: block;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.8;
}

.update-date {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-muted);
  text-align: center;
  margin-top: 40rpx;
}
