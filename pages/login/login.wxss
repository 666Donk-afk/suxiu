.login {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF9F0 0%, #FDF5E6 50%, #FFF9F0 100%);
  position: relative;
  overflow: hidden;
}

.login-bg {
  position: absolute;
  inset: 0;
  pointer-events: none;
}

.bg-pattern {
  position: absolute;
  inset: 0;
  opacity: 0.04;
  background-image:
    radial-gradient(circle at 20% 30%, var(--color-primary) 1px, transparent 1px),
    radial-gradient(circle at 80% 70%, var(--color-primary) 1px, transparent 1px);
  background-size: 48rpx 48rpx;
}

.bg-glow {
  position: absolute;
  top: 20%;
  left: 50%;
  transform: translateX(-50%);
  width: 600rpx;
  height: 600rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(160, 48, 31, 0.06) 0%, transparent 70%);
}

.login-body {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 48rpx calc(env(safe-area-inset-bottom) + 48rpx);
  opacity: 0;
  transition: opacity 400ms ease;
}

.login-body.visible {
  opacity: 1;
}

/* Logo */
.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 48rpx;
}

.login-logo {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 24rpx;
}

.app-name {
  font-size: 52rpx;
  color: var(--color-primary);
  letter-spacing: 10rpx;
}

.tagline {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  margin-top: 16rpx;
  letter-spacing: 4rpx;
}

/* 插画 - 文化长卷 */
.illus-section {
  width: 100%;
  height: 36vh;
  max-height: 480rpx;
  position: relative;
  margin-bottom: 60rpx;
}

.scroll-frame {
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, #E8D5B5 0%, #F5E6D0 8%, #FFF9F0 15%, #FFF9F0 85%, #F5E6D0 92%, #E8D5B5 100%);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
  position: relative;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.scroll-inner {
  display: flex;
  gap: 20rpx;
  padding: 40rpx;
}

.heritage-thumb {
  width: 140rpx;
  height: 180rpx;
  border-radius: var(--radius-sm);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.scroll-deco {
  position: absolute;
  top: 0;
  bottom: 0;
  width: 24rpx;
  background: linear-gradient(90deg, rgba(160, 48, 31, 0.15), transparent);
}

.scroll-deco.left { left: 0; }
.scroll-deco.right {
  right: 0;
  background: linear-gradient(270deg, rgba(160, 48, 31, 0.15), transparent);
}

.pattern-overlay {
  position: absolute;
  bottom: -20rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 200rpx;
  height: 40rpx;
  border-top: 2rpx solid rgba(160, 48, 31, 0.15);
  border-radius: 50% 50% 0 0;
}

.float-anim {
  animation: floatSoft 5s ease-in-out infinite;
}

/* 按钮 */
.action-section {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.login-btn {
  width: 80%;
  padding: 28rpx 0;
  background: var(--color-primary);
  color: #fff;
  font-size: 30rpx;
  border-radius: var(--radius-pill);
  border: none;
  letter-spacing: 2rpx;
  box-shadow: 0 8rpx 28rpx rgba(160, 48, 31, 0.3);
  transition: transform 200ms ease;
}

.login-btn::after {
  border: none;
}

.login-btn:active {
  transform: scale(0.96);
}

.guest-btn {
  margin-top: 32rpx;
  font-size: 26rpx;
  color: var(--color-text-muted);
  padding: 16rpx 32rpx;
}

/* 协议 */
.agreement {
  margin-top: 48rpx;
  text-align: center;
  font-size: 22rpx;
  line-height: 1.8;
  padding: 0 20rpx;
}

.agree-text {
  color: var(--color-text-muted);
}

.agree-link {
  color: var(--color-primary);
}

/* 渐入动画 */
.fade-in-item {
  opacity: 0;
  transform: translateY(16rpx);
  animation: loginFadeIn 350ms ease forwards;
}

.delay-1 { animation-delay: 100ms; }
.delay-2 { animation-delay: 200ms; }
.delay-3 { animation-delay: 300ms; }
.delay-4 { animation-delay: 400ms; }
.delay-5 { animation-delay: 500ms; }

@keyframes loginFadeIn {
  to { opacity: 1; transform: translateY(0); }
}

@keyframes floatSoft {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10rpx); }
}
