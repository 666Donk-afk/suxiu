.page {
  min-height: 100vh;
  background: transparent;
}

.search-bar {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  background: #A0301F;
  gap: 16rpx;
}

.search-input-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 999rpx;
  padding: 16rpx 24rpx;
}

.search-icon {
  color: #A0301F;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
}

.search-action {
  color: #fff;
  font-size: 28rpx;
}

.history {
  padding: 32rpx;
}

.history-header {
  display: flex;
  justify-content: space-between;
  font-size: 26rpx;
  color: #8B7D6B;
  margin-bottom: 16rpx;
}

.clear {
  color: #A0301F;
}

.history-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.history-tag {
  padding: 10rpx 24rpx;
  background: #fff;
  border-radius: 999rpx;
  font-size: 24rpx;
}

.result-section {
  padding: 0 32rpx 32rpx;
}

.result-label {
  font-size: 28rpx;
  font-weight: 700;
  color: #A0301F;
  margin-bottom: 16rpx;
  display: block;
}

.result-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.result-cover {
  width: 100rpx;
  height: 100rpx;
  border-radius: 8rpx;
  margin-right: 20rpx;
  background: #F0EBE3;
}

.result-name {
  font-size: 30rpx;
  display: block;
}

.result-desc {
  font-size: 24rpx;
  color: #8B7D6B;
  margin-top: 4rpx;
}
