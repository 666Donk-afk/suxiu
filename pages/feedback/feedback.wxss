.page {
  min-height: 100vh;
  background: transparent;
  padding: 32rpx;
}

.form {
  padding: 32rpx;
}

.label {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
  display: block;
}

.textarea {
  width: 100%;
  height: 300rpx;
  background: #F9F3E7;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.count {
  display: block;
  text-align: right;
  font-size: 24rpx;
  color: #8B7D6B;
  margin: 12rpx 0 32rpx;
}

.submit {
  width: 100%;
}
