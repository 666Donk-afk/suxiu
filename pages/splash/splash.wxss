.splash {
  min-height: 100vh;
  position: relative;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.splash.fade-out {
  animation: splashFadeOut 400ms ease forwards;
}

.splash-bg-img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}

.splash-content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0 64rpx;
  margin-top: -4vh;
}

.logo-wrap {
  opacity: 0;
  transform: scale(0.88);
  transition: opacity 420ms ease, transform 420ms ease;
}

.logo-wrap.visible {
  opacity: 1;
  transform: scale(1);
}

.splash-logo {
  width: 176rpx;
  height: 176rpx;
}

.brand-name {
  font-size: 64rpx;
  font-weight: 700;
  color: #8B2E26;
  margin-top: 36rpx;
  letter-spacing: 10rpx;
  opacity: 0;
  transform: translateY(20rpx);
  transition: opacity 380ms ease 120ms, transform 380ms ease 120ms;
}

.brand-name.visible {
  opacity: 1;
  transform: translateY(0);
}

.brand-slogan {
  font-size: 28rpx;
  color: #6B5348;
  margin-top: 32rpx;
  text-align: center;
  line-height: 1.75;
  letter-spacing: 1rpx;
  opacity: 0;
  transform: translateY(16rpx);
  transition: opacity 380ms ease 220ms, transform 380ms ease 220ms;
}

.brand-slogan.visible {
  opacity: 1;
  transform: translateY(0);
}

@keyframes splashFadeOut {
  from { opacity: 1; }
  to { opacity: 0; }
}
