.splash {
  min-height: 100vh;
  background: linear-gradient(165deg, #FFF9F0 0%, #FDF5E6 45%, #F9F0E0 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}

.splash.fade-out {
  animation: splashFadeOut 400ms ease forwards;
}

.splash-bg {
  position: absolute;
  inset: 0;
  pointer-events: none;
}

.deco-circle {
  position: absolute;
  border-radius: 50%;
  opacity: 0.12;
  background: var(--color-primary);
}

.deco-1 {
  width: 480rpx;
  height: 480rpx;
  top: -120rpx;
  right: -100rpx;
}

.deco-2 {
  width: 320rpx;
  height: 320rpx;
  bottom: 80rpx;
  left: -80rpx;
}

.deco-line {
  position: absolute;
  bottom: 160rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 200rpx;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, rgba(160, 48, 31, 0.25), transparent);
}

.splash-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  z-index: 1;
  padding: 0 60rpx;
}

.logo-wrap {
  opacity: 0;
  transform: scale(0.85);
  transition: all 400ms ease;
}

.logo-wrap.visible {
  opacity: 1;
  transform: scale(1);
}

.splash-logo {
  width: 160rpx;
  height: 160rpx;
}

.brand-name {
  font-size: 56rpx;
  color: var(--color-primary);
  margin-top: 40rpx;
  letter-spacing: 8rpx;
  opacity: 0;
  transform: translateY(16rpx);
  transition: all 350ms ease 100ms;
}

.brand-name.visible {
  opacity: 1;
  transform: translateY(0);
}

.brand-slogan {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  margin-top: 48rpx;
  text-align: center;
  line-height: 1.8;
  letter-spacing: 2rpx;
  opacity: 0;
  transform: translateY(12rpx);
  transition: all 350ms ease 150ms;
}

.brand-slogan.visible {
  opacity: 1;
  transform: translateY(0);
}

@keyframes splashFadeOut {
  from { opacity: 1; }
  to { opacity: 0; }
}
