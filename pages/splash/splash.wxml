<view class="splash {{fading ? 'fade-out' : ''}}">
  <image class="splash-bg-img" src="/images/brand/splash-bg.jpg" mode="aspectFill" />

  <view class="splash-content">
    <view class="logo-wrap {{showLogo ? 'visible' : ''}}">
      <image class="logo-img splash-logo" src="/images/brand/logo.png" mode="aspectFit" />
    </view>
    <text class="brand-name title-serif {{showName ? 'visible' : ''}}">{{i18n.appName}}</text>
    <text class="brand-slogan {{showSlogan ? 'visible' : ''}}">{{i18n.slogan}}</text>
  </view>
</view>
