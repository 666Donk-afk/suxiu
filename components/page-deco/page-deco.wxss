.page-deco {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  z-index: 0;
  overflow: hidden;
  background: transparent;
}

.deco {
  position: absolute;
  pointer-events: none;
}

.deco-cloud-top {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  display: block;
  background-color: transparent;
}

.deco-glow-bottom {
  bottom: 0;
  left: 0;
  right: 0;
  height: 280rpx;
  background: linear-gradient(180deg, transparent 0%, rgba(255, 255, 255, 0.5) 100%);
}
