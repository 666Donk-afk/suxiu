.msg-row {
  display: flex;
  align-items: flex-start;
  margin-bottom: 28rpx;
}

.msg-avatar-slot {
  flex-shrink: 0;
  margin-right: 16rpx;
}

.msg-user {
  flex-direction: row-reverse;
}

.msg-body {
  max-width: 88%;
}

.msg-bubble {
  max-width: 78%;
  padding: 20rpx 24rpx;
  border-radius: 24rpx;
  background: #fff;
  box-shadow: 0 4rpx 24rpx rgba(160, 48, 31, 0.06);
}

.msg-user .msg-bubble {
  background: linear-gradient(135deg, #A0301F, #B34D2E);
}

.msg-user .msg-text {
  color: #fff;
}

.msg-text {
  font-size: 28rpx;
  line-height: 1.75;
  color: var(--color-text, #1A1A1A);
  white-space: pre-wrap;
  word-break: break-word;
}

.msg-error .msg-text {
  color: #B34D2E;
}
