.heritage-card {
  display: flex;
  flex-direction: column;
  padding: var(--spacing-card, 24rpx);
  background: var(--color-card, #FFFCF7);
  border-radius: var(--radius-lg, 24rpx);
  border: 1rpx solid var(--color-border, rgba(158, 43, 37, 0.12));
  box-shadow: var(--shadow-card, 0 8rpx 32rpx rgba(44, 36, 24, 0.06));
}

.card-body {
  display: flex;
}

.cover {
  width: 180rpx;
  height: 180rpx;
  border-radius: var(--radius-sm, 8rpx);
  flex-shrink: 0;
  background: var(--color-bg-cream);
  border: 1rpx solid var(--color-border);
}

.info {
  flex: 1;
  margin-left: 20rpx;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.row-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.name {
  font-size: 32rpx;
  font-weight: 700;
  flex: 1;
  color: var(--color-text);
  letter-spacing: 1rpx;
}

.tag-level-outline {
  background: var(--color-tag-bg);
  border: 1rpx solid rgba(158, 43, 37, 0.2);
  color: var(--color-primary);
  font-size: 20rpx;
  padding: 2rpx 14rpx;
  border-radius: 6rpx;
}

.meta {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin: 8rpx 0;
}

.summary-wrap {
  position: relative;
  margin-top: 4rpx;
}

.summary-measure-full,
.summary-measure-clamp {
  position: absolute;
  left: 0;
  right: 0;
  visibility: hidden;
  pointer-events: none;
  font-size: 24rpx;
  line-height: 1.6;
  z-index: -1;
}

.summary-measure-clamp {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
  overflow: hidden;
}

.summary-text {
  font-size: 24rpx;
  line-height: 1.7;
  color: var(--color-text-body);
  word-break: break-all;
}

.summary-text.is-clamped {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
  overflow: hidden;
}

.card-divider {
  height: 1rpx;
  background: var(--color-divider);
  margin-top: 20rpx;
}

.expand-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 16rpx 0 0;
  color: var(--color-primary);
  font-size: 26rpx;
}

.expand-chevron {
  font-size: 22rpx;
  line-height: 1;
}

.footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 16rpx;
}

.like {
  display: flex;
  align-items: center;
  color: var(--color-accent);
  font-size: 22rpx;
}

.heart {
  margin-right: 6rpx;
}

.fav-btn {
  padding: 6rpx 20rpx;
  border: 1rpx solid var(--color-primary);
  color: var(--color-primary);
  font-size: 22rpx;
  border-radius: 999rpx;
  transition: all 200ms;
}

.fav-btn.favorited {
  background: var(--color-primary);
  color: #fff;
}
