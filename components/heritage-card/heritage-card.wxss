.heritage-card {
  display: flex;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.cover {
  width: 180rpx;
  height: 180rpx;
  border-radius: var(--radius-sm, 8rpx);
  flex-shrink: 0;
  background: #F0EBE3;
}

.info {
  flex: 1;
  margin-left: 20rpx;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.row-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.name {
  font-size: 32rpx;
  flex: 1;
}

.meta {
  font-size: 24rpx;
  color: var(--color-text-secondary, #8B7D6B);
  margin: 8rpx 0;
}

.summary-wrap {
  position: relative;
  margin-top: 4rpx;
}

.summary-measure-full,
.summary-measure-clamp {
  position: absolute;
  left: 0;
  right: 0;
  visibility: hidden;
  pointer-events: none;
  font-size: 24rpx;
  line-height: 1.5;
  z-index: -1;
}

.summary-measure-clamp {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 4;
  overflow: hidden;
}

.summary-body {
  position: relative;
  font-size: 24rpx;
  line-height: 1.5;
  color: var(--color-text-muted, #8E8E8E);
}

.summary-body.is-clamped .summary-text {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 4;
  overflow: hidden;
}

.summary-text {
  word-break: break-all;
}

.summary-toggle {
  color: #A0301F;
  font-size: 24rpx;
  line-height: 1.5;
  white-space: nowrap;
}

.footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 12rpx;
}

.like {
  display: flex;
  align-items: center;
  color: #E67E22;
  font-size: 22rpx;
}

.heart {
  margin-right: 6rpx;
}

.fav-btn {
  padding: 6rpx 20rpx;
  border: 1rpx solid #A0301F;
  color: #A0301F;
  font-size: 22rpx;
  border-radius: 999rpx;
  transition: all 200ms;
}

.fav-btn.favorited {
  background: #A0301F;
  color: #fff;
}
