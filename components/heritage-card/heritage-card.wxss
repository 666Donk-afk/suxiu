.heritage-card {
  display: flex;
  flex-direction: column;
  padding: var(--spacing-card, 24rpx);
  background: var(--color-card, #FFFFFF);
  border-radius: var(--radius-lg, 24rpx);
  box-shadow: var(--shadow-card, 0 4rpx 24rpx rgba(160, 48, 31, 0.06));
}

.card-body {
  display: flex;
}

.cover {
  width: 180rpx;
  height: 180rpx;
  border-radius: var(--radius-sm, 8rpx);
  flex-shrink: 0;
  background: #F0EBE3;
}

.info {
  flex: 1;
  margin-left: 20rpx;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.row-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.name {
  font-size: 32rpx;
  flex: 1;
}

.tag-level-outline {
  background: transparent;
  border: 1rpx solid var(--color-primary-light, #B34D2E);
  color: var(--color-primary, #A0301F);
  font-size: 20rpx;
  padding: 2rpx 14rpx;
}

.meta {
  font-size: 24rpx;
  color: var(--color-text-secondary, #8B7D6B);
  margin: 8rpx 0;
}

.summary-wrap {
  position: relative;
  margin-top: 4rpx;
}

.summary-measure-full,
.summary-measure-clamp {
  position: absolute;
  left: 0;
  right: 0;
  visibility: hidden;
  pointer-events: none;
  font-size: 24rpx;
  line-height: 1.5;
  z-index: -1;
}

.summary-measure-clamp {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
  overflow: hidden;
}

.summary-text {
  font-size: 24rpx;
  line-height: 1.5;
  color: var(--color-text-muted, #8E8E8E);
  word-break: break-all;
}

.summary-text.is-clamped {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
  overflow: hidden;
}

.card-divider {
  height: 1rpx;
  background: var(--color-divider, #E8E0D0);
  margin-top: 20rpx;
}

.expand-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 16rpx 0 0;
  color: var(--color-primary, #A0301F);
  font-size: 26rpx;
}

.expand-chevron {
  font-size: 22rpx;
  line-height: 1;
}

.footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 16rpx;
}

.like {
  display: flex;
  align-items: center;
  color: #E67E22;
  font-size: 22rpx;
}

.heart {
  margin-right: 6rpx;
}

.fav-btn {
  padding: 6rpx 20rpx;
  border: 1rpx solid #A0301F;
  color: #A0301F;
  font-size: 22rpx;
  border-radius: 999rpx;
  transition: all 200ms;
}

.fav-btn.favorited {
  background: #A0301F;
  color: #fff;
}
