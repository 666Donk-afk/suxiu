.login {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: var(--color-card, #FFFBF5);
}

/* 顶部品牌区 */
.login-hero {
  position: relative;
  flex-shrink: 0;
  min-height: 42vh;
  padding: 24rpx 48rpx 120rpx;
  background: linear-gradient(180deg, #F9E8C8 0%, #F5DCC0 72%, #F0D4B8 100%);
  overflow: hidden;
}

.login-hero::before {
  content: '';
  position: absolute;
  top: -80rpx;
  right: -60rpx;
  width: 320rpx;
  height: 320rpx;
  border-radius: 50%;
  background: rgba(158, 43, 37, 0.06);
  pointer-events: none;
}

.login-hero::after {
  content: '';
  position: absolute;
  bottom: 160rpx;
  left: -100rpx;
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  background: rgba(158, 43, 37, 0.04);
  pointer-events: none;
}

.hero-back {
  position: relative;
  z-index: 2;
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.hero-back-icon {
  font-size: 52rpx;
  line-height: 1;
  color: var(--color-text);
  font-weight: 300;
}

.hero-brand {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: calc(42vh - 200rpx);
  opacity: 0;
  transform: translateY(20rpx);
  transition: opacity 400ms ease, transform 400ms ease;
}

.hero-brand.visible {
  opacity: 1;
  transform: translateY(0);
}

.logo-img {
  width: 128rpx;
  height: 128rpx;
  margin-bottom: 28rpx;
}

.app-name {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--color-primary);
  letter-spacing: 8rpx;
}

.tagline {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  letter-spacing: 4rpx;
}

.hero-curve {
  position: absolute;
  left: -8%;
  right: -8%;
  bottom: -72rpx;
  height: 140rpx;
  background: var(--color-card, #FFFBF5);
  border-radius: 50%;
  z-index: 2;
}

/* 底部登录区 */
.login-panel {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 48rpx calc(env(safe-area-inset-bottom) + 48rpx);
  opacity: 0;
  transform: translateY(16rpx);
  transition: opacity 450ms ease 120ms, transform 450ms ease 120ms;
}

.login-panel.visible {
  opacity: 1;
  transform: translateY(0);
}

.welcome-title {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--color-text);
  letter-spacing: 4rpx;
  margin-bottom: 64rpx;
}

.action-section {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 28rpx;
}

.login-btn {
  width: 100%;
  margin: 0;
  padding: 0;
  border-radius: 999rpx;
  font-size: 30rpx;
  line-height: 1;
  border: none;
}

.login-btn::after {
  border: none;
}

.btn-inner {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 28rpx 0;
}

.login-btn-primary {
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
  color: #fff;
  box-shadow: 0 10rpx 28rpx rgba(158, 43, 37, 0.28);
}

.login-btn-primary:active {
  opacity: 0.92;
  transform: scale(0.98);
}

.wx-badge {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.22);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 700;
  color: #fff;
}

.login-btn-outline {
  background: transparent;
  color: var(--color-text-secondary);
  border: 2rpx solid var(--color-border, rgba(158, 43, 37, 0.18));
  padding: 26rpx 0;
}

.login-btn-outline:active {
  background: rgba(158, 43, 37, 0.04);
}

/* 协议 */
.agreement {
  margin-top: auto;
  padding-top: 64rpx;
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  max-width: 100%;
}

.agree-check {
  width: 32rpx;
  height: 32rpx;
  margin-top: 4rpx;
  flex-shrink: 0;
  border-radius: 50%;
  border: 2rpx solid var(--color-border, rgba(158, 43, 37, 0.25));
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 200ms ease;
}

.agree-check.checked {
  background: var(--color-primary);
  border-color: var(--color-primary);
}

.agree-check-mark {
  font-size: 20rpx;
  color: #fff;
  line-height: 1;
}

.agree-copy {
  flex: 1;
  font-size: 22rpx;
  line-height: 1.7;
}

.agree-text {
  color: var(--color-text-muted);
}

.agree-link {
  color: var(--color-primary);
}
