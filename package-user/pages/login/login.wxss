.login {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: #FFFBF5;
}

/* 顶部品牌区 */
.login-hero {
  position: relative;
  flex-shrink: 0;
  min-height: 44vh;
  padding: 24rpx 48rpx 120rpx;
  overflow: hidden;
}

.login-hero-bg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}

.hero-back {
  position: relative;
  z-index: 3;
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.hero-back-icon {
  font-size: 52rpx;
  line-height: 1;
  color: #4A3428;
  font-weight: 300;
}

.hero-brand {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: calc(44vh - 200rpx);
  opacity: 0;
  transform: translateY(20rpx);
  transition: opacity 400ms ease, transform 400ms ease;
}

.hero-brand.visible {
  opacity: 1;
  transform: translateY(0);
}

.logo-img {
  width: 132rpx;
  height: 132rpx;
  margin-bottom: 24rpx;
}

.app-name {
  font-size: 52rpx;
  font-weight: 700;
  color: #4A3428;
  letter-spacing: 12rpx;
}

.tagline {
  margin-top: 18rpx;
  font-size: 26rpx;
  color: #6B5348;
  letter-spacing: 6rpx;
}

.hero-curve {
  position: absolute;
  left: -10%;
  right: -10%;
  bottom: -76rpx;
  height: 148rpx;
  background: #FFFBF5;
  border-radius: 50%;
  z-index: 2;
}

/* 底部登录区 */
.login-panel {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 48rpx calc(env(safe-area-inset-bottom) + 48rpx);
  background: #FFFBF5;
  opacity: 0;
  transform: translateY(16rpx);
  transition: opacity 450ms ease 120ms, transform 450ms ease 120ms;
}

.login-panel.visible {
  opacity: 1;
  transform: translateY(0);
}

.welcome-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #4A3428;
  letter-spacing: 4rpx;
  margin-bottom: 56rpx;
}

.action-section {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 28rpx;
}

.login-btn {
  width: 100%;
  margin: 0;
  padding: 0;
  border-radius: 999rpx;
  font-size: 30rpx;
  line-height: 1;
  border: none;
}

.login-btn::after {
  border: none;
}

.btn-inner {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 28rpx 0;
}

.login-btn-primary {
  background: #E8D4B8;
  color: #4A3428;
  box-shadow: 0 8rpx 24rpx rgba(74, 52, 40, 0.08);
}

.login-btn-primary:active {
  opacity: 0.92;
  transform: scale(0.98);
}

.wx-badge {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(74, 52, 40, 0.12);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 700;
  color: #4A3428;
}

.login-btn-outline {
  background: #FFFBF5;
  color: #6B5348;
  border: 2rpx solid rgba(74, 52, 40, 0.22);
  padding: 26rpx 0;
}

.login-btn-outline:active {
  background: rgba(74, 52, 40, 0.04);
}

/* 协议 */
.agreement {
  margin-top: auto;
  padding-top: 64rpx;
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  max-width: 100%;
}

.agree-check {
  width: 32rpx;
  height: 32rpx;
  margin-top: 4rpx;
  flex-shrink: 0;
  border-radius: 50%;
  border: 2rpx solid rgba(74, 52, 40, 0.22);
  background: #FFFBF5;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 200ms ease;
}

.agree-check.checked {
  background: #8B5E3C;
  border-color: #8B5E3C;
}

.agree-check-mark {
  font-size: 20rpx;
  color: #fff;
  line-height: 1;
}

.agree-copy {
  flex: 1;
  font-size: 22rpx;
  line-height: 1.7;
}

.agree-text {
  color: #8A7968;
}

.agree-link {
  color: #8B5E3C;
}
