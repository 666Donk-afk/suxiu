<view class="login page-fade-in">
  <!-- 顶部品牌区（弧形过渡） -->
  <view class="login-hero" style="padding-top: {{statusBarHeight}}px;">
    <view class="hero-back tap-active" wx:if="{{showBack}}" bindtap="onBack">
      <text class="hero-back-icon">‹</text>
    </view>

    <view class="hero-brand {{showContent ? 'visible' : ''}}">
      <image class="logo-img" src="/images/brand/logo.png" mode="aspectFit" />
      <text class="app-name title-serif">{{i18n.appName}}</text>
      <text class="tagline">{{i18n.tagline}}</text>
    </view>

    <view class="hero-curve" aria-hidden="true"></view>
  </view>

  <!-- 底部登录操作区 -->
  <view class="login-panel {{showContent ? 'visible' : ''}}">
    <text class="welcome-title title-serif">{{i18n.welcomeTitle}}</text>

    <view class="action-section">
      <button class="login-btn login-btn-primary tap-active" bindtap="onLogin">
        <view class="btn-inner">
          <view class="wx-badge">微</view>
          <text>{{i18n.loginBtn}}</text>
        </view>
      </button>
      <button class="login-btn login-btn-outline tap-active" bindtap="onGuest">{{i18n.guestBtn}}</button>
    </view>

    <view class="agreement tap-active" bindtap="toggleAgree">
      <view class="agree-check {{agreed ? 'checked' : ''}}">
        <text wx:if="{{agreed}}" class="agree-check-mark">✓</text>
      </view>
      <view class="agree-copy">
        <text class="agree-text">{{i18n.agreePrefix}}</text>
        <text class="agree-link" catchtap="goAgreement" data-type="user">{{i18n.userAgreement}}</text>
        <text class="agree-text">{{i18n.agreeAnd}}</text>
        <text class="agree-link" catchtap="goAgreement" data-type="privacy">{{i18n.privacyPolicy}}</text>
      </view>
    </view>
  </view>
</view>
