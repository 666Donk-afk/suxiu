.tab-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  height: calc(108rpx + env(safe-area-inset-bottom));
  padding-bottom: env(safe-area-inset-bottom);
  background: rgba(255, 252, 247, 0.96);
  border-top: 1rpx solid rgba(158, 43, 37, 0.1);
  z-index: 999;
  font-family: "Songti SC", "STSong", "SimSun", serif;
  box-shadow: 0 -4rpx 24rpx rgba(44, 36, 24, 0.05);
  backdrop-filter: blur(12px);
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 10rpx;
}

.tab-text {
  font-size: 20rpx;
  color: #8A7968;
  margin-top: 6rpx;
  letter-spacing: 1rpx;
}

.tab-item.active .tab-text {
  color: #9E2B25;
  font-weight: 700;
}

.tab-icon {
  width: 44rpx;
  height: 44rpx;
  opacity: 0.55;
}

.tab-item.active .tab-icon {
  opacity: 1;
}
