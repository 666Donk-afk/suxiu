.tab-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  height: calc(100rpx + env(safe-area-inset-bottom));
  padding-bottom: env(safe-area-inset-bottom);
  background: #FFFFFF;
  border-top: 1rpx solid #F0EBE3;
  z-index: 999;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 8rpx;
}

.tab-text {
  font-size: 22rpx;
  color: #999999;
  margin-top: 6rpx;
}

.tab-item.active .tab-text {
  color: #A0301F;
  font-weight: 600;
}

.tab-icon {
  width: 44rpx;
  height: 44rpx;
  position: relative;
}

/* 首页 - 传统门楼 */
.icon-home::before {
  content: '';
  position: absolute;
  left: 50%;
  bottom: 4rpx;
  transform: translateX(-50%);
  width: 32rpx;
  height: 20rpx;
  border: 3rpx solid #999;
  border-top: none;
  border-radius: 0 0 4rpx 4rpx;
}

.icon-home::after {
  content: '';
  position: absolute;
  left: 50%;
  top: 6rpx;
  transform: translateX(-50%);
  width: 0;
  height: 0;
  border-left: 18rpx solid transparent;
  border-right: 18rpx solid transparent;
  border-bottom: 12rpx solid #999;
}

/* 城市 - 塔 */
.icon-city::before {
  content: '';
  position: absolute;
  left: 50%;
  bottom: 4rpx;
  transform: translateX(-50%);
  width: 28rpx;
  height: 24rpx;
  border: 3rpx solid #999;
  border-radius: 2rpx;
}

.icon-city::after {
  content: '';
  position: absolute;
  left: 50%;
  top: 4rpx;
  transform: translateX(-50%);
  width: 12rpx;
  height: 8rpx;
  border: 3rpx solid #999;
  border-bottom: none;
}

/* 收藏 - 心形 */
.icon-heart::before {
  content: '';
  position: absolute;
  left: 8rpx;
  top: 10rpx;
  width: 14rpx;
  height: 22rpx;
  background: #999;
  border-radius: 14rpx 14rpx 0 0;
  transform: rotate(-45deg);
  transform-origin: bottom right;
}

.icon-heart::after {
  content: '';
  position: absolute;
  right: 8rpx;
  top: 10rpx;
  width: 14rpx;
  height: 22rpx;
  background: #999;
  border-radius: 14rpx 14rpx 0 0;
  transform: rotate(45deg);
  transform-origin: bottom left;
}

/* 我的 - 人 */
.icon-user::before {
  content: '';
  position: absolute;
  left: 50%;
  top: 6rpx;
  transform: translateX(-50%);
  width: 16rpx;
  height: 16rpx;
  border: 3rpx solid #999;
  border-radius: 50%;
}

.icon-user::after {
  content: '';
  position: absolute;
  left: 50%;
  bottom: 4rpx;
  transform: translateX(-50%);
  width: 28rpx;
  height: 14rpx;
  border: 3rpx solid #999;
  border-bottom: none;
  border-radius: 14rpx 14rpx 0 0;
}

.icon-active.icon-home::before,
.icon-active.icon-home::after,
.icon-active.icon-city::before,
.icon-active.icon-city::after,
.icon-active.icon-user::before,
.icon-active.icon-user::after {
  border-color: #A0301F;
}

.icon-active.icon-heart::before,
.icon-active.icon-heart::after {
  background: #A0301F;
}
