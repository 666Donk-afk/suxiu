<view class="tab-bar">
  <view
    wx:for="{{list}}"
    wx:key="pagePath"
    class="tab-item {{selected === index ? 'active' : ''}}"
    data-path="{{item.pagePath}}"
    data-index="{{index}}"
    bindtap="switchTab"
  >
    <image class="tab-icon" src="{{item.iconImage}}" mode="aspectFit" />
    <text class="tab-text">{{item.text}}</text>
  </view>
</view>
