.recognize-card {
  background: var(--color-card);
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: var(--shadow-soft);
  border: 1rpx solid var(--color-border);
}

.recognize-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.recognize-icon {
  font-size: 36rpx;
}

.recognize-title {
  font-size: 32rpx;
  color: var(--color-primary);
  font-weight: 600;
}

.recognize-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.meta-tag {
  font-size: 22rpx;
  color: var(--color-tag-text);
  background: var(--color-tag-bg);
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
}

.meta-confidence {
  color: var(--color-text-secondary);
  background: var(--color-bg-cream);
}

.recognize-location {
  margin-bottom: 12rpx;
}

.loc-label {
  font-size: 22rpx;
  color: var(--color-text-muted);
  margin-right: 8rpx;
}

.loc-value {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.recognize-summary {
  margin-bottom: 16rpx;
}

.summary-text {
  font-size: 26rpx;
  line-height: 1.7;
  color: var(--color-text-secondary);
}

.recognize-action {
  display: inline-block;
  font-size: 26rpx;
  color: #fff;
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-dark));
  padding: 14rpx 28rpx;
  border-radius: 999rpx;
  box-shadow: 0 4rpx 12rpx rgba(158, 43, 37, 0.25);
}
