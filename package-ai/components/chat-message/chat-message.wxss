.msg-row {
  display: flex;
  align-items: flex-start;
  margin-bottom: 28rpx;
}

.msg-avatar-slot {
  flex-shrink: 0;
  margin-right: 16rpx;
}

.msg-user {
  flex-direction: row-reverse;
}

.msg-body {
  max-width: 88%;
}

.msg-image-wrap {
  max-width: 78%;
}

.msg-user .msg-image-wrap {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.msg-image {
  width: 280rpx;
  height: 280rpx;
  border-radius: 20rpx;
  background: var(--color-bg-cream);
}

.msg-image-caption {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: var(--color-text-muted);
}

.msg-bubble {
  max-width: 78%;
  padding: 20rpx 24rpx;
  border-radius: 24rpx;
  background: var(--color-card);
  box-shadow: var(--shadow-soft);
  border: 1rpx solid var(--color-border);
}

.msg-user .msg-bubble {
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-dark));
  border-color: transparent;
  box-shadow: 0 4rpx 12rpx rgba(158, 43, 37, 0.25);
}

.msg-user .msg-text {
  color: #fff;
}

.msg-text {
  font-size: 28rpx;
  line-height: 1.75;
  color: var(--color-text);
  white-space: pre-wrap;
  word-break: break-word;
}

.msg-error .msg-text {
  color: var(--color-primary-light);
}
