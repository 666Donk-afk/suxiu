.route-card {
  background: var(--color-card);
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: var(--shadow-soft);
  border: 1rpx solid var(--color-border);
}

.route-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.route-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.route-title {
  font-size: 32rpx;
  color: var(--color-primary);
  font-weight: 600;
}

.route-meta {
  display: flex;
  align-items: center;
  padding: 12rpx 16rpx;
  background: var(--color-bg-cream);
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

.meta-label {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-right: 12rpx;
}

.meta-value {
  font-size: 26rpx;
  color: var(--color-primary);
  font-weight: 500;
}

.steps-title {
  display: block;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  margin-bottom: 16rpx;
}

.step-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.step-item:last-child {
  margin-bottom: 0;
}

.step-index {
  flex-shrink: 0;
  width: 44rpx;
  height: 44rpx;
  line-height: 44rpx;
  text-align: center;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-dark));
  color: #fff;
  font-size: 24rpx;
  margin-right: 16rpx;
}

.step-name {
  display: block;
  font-size: 28rpx;
  color: var(--color-text);
  font-weight: 500;
  margin-bottom: 6rpx;
}

.step-desc {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-muted);
  line-height: 1.6;
}

.route-reason {
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx dashed var(--color-divider);
}

.reason-label {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-bottom: 8rpx;
}

.reason-text {
  display: block;
  font-size: 26rpx;
  color: var(--color-text);
  line-height: 1.7;
}
