page {
  background: var(--color-bg-top);
}

.page.ai-guide-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: var(--app-bg-gradient);
  box-sizing: border-box;
}

.page-body.ai-guide-body {
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
  position: relative;
  z-index: 1;
}

.nav-bar {
  flex-shrink: 0;
  background: rgba(255, 251, 245, 0.92);
  border-bottom: 1rpx solid var(--color-divider);
}

.nav-inner {
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  box-sizing: border-box;
}

.nav-back {
  width: 64rpx;
  flex-shrink: 0;
  font-size: 48rpx;
  color: var(--color-text);
  line-height: 1;
  font-weight: 300;
}

.nav-center {
  flex: 1;
  display: flex;
  align-items: center;
  min-width: 0;
  gap: 12rpx;
  padding: 0 8rpx;
}

.nav-texts {
  flex: 1;
  min-width: 0;
}

.nav-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.nav-sub {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-secondary);
  margin-top: 2rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.nav-action {
  flex-shrink: 0;
  font-size: 26rpx;
  color: var(--color-primary);
  font-weight: 600;
  padding: 8rpx 0 8rpx 12rpx;
}

.context-bar {
  flex-shrink: 0;
  padding: 12rpx 32rpx;
  background: rgba(255, 251, 245, 0.72);
  border-bottom: 1rpx solid var(--color-divider);
}

.context-text {
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

.chat-scroll {
  flex: 1;
  min-height: 0;
  background: transparent;
}

.chat-list {
  padding: 24rpx 24rpx 16rpx;
}

.typing-row {
  display: flex;
  align-items: flex-start;
  margin-bottom: 28rpx;
}

.typing-avatar-slot {
  flex-shrink: 0;
  margin-right: 16rpx;
}

.typing-bubble {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  background: var(--color-card);
  border-radius: 24rpx;
  border: 1rpx solid var(--color-border);
  box-shadow: var(--shadow-soft);
}

.typing-text {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  margin-right: 12rpx;
}

.typing-dots {
  display: flex;
  gap: 8rpx;
}

.typing-dots .dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: var(--color-primary-light);
  animation: blink 1.2s infinite ease-in-out;
}

.typing-dots .dot:nth-child(2) { animation-delay: 0.2s; }
.typing-dots .dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes blink {
  0%, 80%, 100% { opacity: 0.3; transform: scale(0.85); }
  40% { opacity: 1; transform: scale(1); }
}

.chat-bottom {
  height: 24rpx;
}

.quick-bar {
  flex-shrink: 0;
  padding: 8rpx 0 12rpx;
  background: transparent;
}

.quick-scroll {
  white-space: nowrap;
  padding: 0 24rpx;
}

.quick-chip {
  display: inline-block;
  margin-right: 16rpx;
  padding: 14rpx 24rpx;
  font-size: 24rpx;
  color: var(--color-tag-text);
  background: var(--color-tag-bg);
  border-radius: var(--radius-pill);
  border: 1rpx solid var(--color-border);
}

.photo-preview-bar {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 12rpx 24rpx;
  background: rgba(255, 251, 245, 0.92);
  border-top: 1rpx solid var(--color-divider);
}

.photo-preview-img {
  width: 96rpx;
  height: 96rpx;
  border-radius: 16rpx;
  background: var(--color-bg-cream);
  flex-shrink: 0;
}

.photo-preview-meta {
  flex: 1;
  min-width: 0;
}

.photo-preview-hint {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.photo-preview-remove {
  display: inline-block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: var(--color-primary);
}

.input-bar {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx 24rpx;
  background: rgba(255, 251, 245, 0.92);
  border-top: 1rpx solid var(--color-divider);
  gap: 12rpx;
}

.camera-btn {
  flex-shrink: 0;
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  background: var(--color-card);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid var(--color-border);
}

.camera-btn.disabled {
  opacity: 0.45;
}

.camera-icon {
  font-size: 36rpx;
  line-height: 1;
}

.chat-input {
  flex: 1;
  height: 76rpx;
  padding: 0 28rpx;
  background: var(--color-card);
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-pill);
  font-size: 28rpx;
}

.input-ph {
  color: var(--color-text-muted);
}

.send-btn {
  flex-shrink: 0;
  padding: 0 28rpx;
  height: 76rpx;
  line-height: 76rpx;
  border-radius: var(--radius-pill);
  font-size: 28rpx;
  color: #fff;
  background: rgba(44, 36, 24, 0.18);
  text-align: center;
}

.send-btn.active {
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-dark));
  box-shadow: 0 4rpx 12rpx rgba(158, 43, 37, 0.25);
}

.ai-guide-page .msg-bubble {
  box-shadow: var(--shadow-soft);
  border: 1rpx solid var(--color-border);
}

.ai-guide-page .route-meta {
  background: var(--color-card);
  border: 1rpx solid var(--color-border);
}

.ai-guide-page .meta-confidence {
  background: var(--color-card);
  border: 1rpx solid var(--color-border);
}
