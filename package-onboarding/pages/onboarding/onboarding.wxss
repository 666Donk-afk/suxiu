.onboarding {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF9F0 0%, #FFFFFF 60%, #FDF5E6 100%);
  display: flex;
  flex-direction: column;
  position: relative;
  overflow: hidden;
}

.skip-btn {
  position: absolute;
  top: calc(env(safe-area-inset-top) + 24rpx);
  right: 40rpx;
  z-index: 10;
  font-size: 26rpx;
  color: var(--color-text-muted);
  padding: 12rpx 24rpx;
  background: rgba(255, 255, 255, 0.7);
  border-radius: var(--radius-pill);
}

.swiper {
  flex: 1;
  height: 75vh;
}

.slide {
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 48rpx 40rpx;
}

/* 插画区域 */
.illus {
  width: 100%;
  height: 420rpx;
  position: relative;
  margin-bottom: 60rpx;
  opacity: 0;
  animation: illusFadeIn 400ms ease 200ms forwards;
}

.float-anim {
  animation: illusFadeIn 400ms ease 200ms forwards, floatSoft 4s ease-in-out 600ms infinite;
}

/* 第一页 - 城市 */
.city-skyline {
  position: absolute;
  bottom: 40rpx;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  align-items: flex-end;
  gap: 12rpx;
}

.building {
  background: linear-gradient(180deg, #C45A3A 0%, #A0301F 100%);
  border-radius: 8rpx 8rpx 0 0;
  opacity: 0.85;
}

.b1 { width: 48rpx; height: 120rpx; }
.b2 { width: 64rpx; height: 180rpx; }
.b3 { width: 80rpx; height: 220rpx; }
.b4 { width: 56rpx; height: 150rpx; }
.b5 { width: 44rpx; height: 100rpx; }

.heritage-float {
  position: absolute;
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: var(--color-card);
  box-shadow: var(--shadow-card);
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--font-serif);
  font-size: 32rpx;
  color: var(--color-primary);
}

.h1 { top: 80rpx; left: 80rpx; animation: floatSoft 3s ease-in-out infinite; }
.h2 { top: 140rpx; right: 100rpx; animation: floatSoft 3.5s ease-in-out 0.5s infinite; }
.h3 { top: 200rpx; left: 50%; animation: floatSoft 4s ease-in-out 1s infinite; }

.moon {
  position: absolute;
  top: 40rpx;
  right: 60rpx;
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: radial-gradient(circle at 30% 30%, #FFF5E6, #E8C9A0);
  box-shadow: 0 0 40rpx rgba(232, 201, 160, 0.4);
}

/* 第二页 - 故事 */
.timeline {
  position: absolute;
  left: 80rpx;
  top: 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.tl-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: var(--color-divider);
  border: 4rpx solid var(--color-bg-cream);
}

.tl-dot.active {
  background: var(--color-primary);
  box-shadow: 0 0 16rpx rgba(160, 48, 31, 0.35);
}

.tl-line {
  width: 4rpx;
  height: 80rpx;
  background: linear-gradient(180deg, var(--color-primary), var(--color-divider));
}

.tl-line.short {
  height: 60rpx;
}

.story-scene {
  position: absolute;
  right: 60rpx;
  top: 80rpx;
}

.scene-card {
  width: 200rpx;
  height: 120rpx;
  background: var(--color-card);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-card);
  margin-bottom: 24rpx;
  display: flex;
  align-items: flex-end;
  padding: 16rpx;
}

.scene-card.c1 {
  border-left: 6rpx solid var(--color-primary);
}

.scene-card.c2 {
  width: 160rpx;
  margin-left: 40rpx;
  border-left: 6rpx solid var(--color-accent);
}

.scene-label {
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

.scene-figure {
  position: absolute;
  bottom: 40rpx;
  left: 120rpx;
  width: 100rpx;
  height: 140rpx;
  background: linear-gradient(180deg, #B34D2E 0%, #A0301F 60%, transparent 60%);
  border-radius: 50rpx 50rpx 0 0;
  opacity: 0.2;
}

/* 第三页 - 分享 */
.phone-mock {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 240rpx;
  height: 400rpx;
  border: 6rpx solid var(--color-text);
  border-radius: 32rpx;
  background: var(--color-card);
  padding: 16rpx;
}

.phone-screen {
  height: 100%;
  background: var(--color-bg);
  border-radius: 20rpx;
  padding: 20rpx;
}

.screen-card {
  height: 100rpx;
  background: linear-gradient(135deg, #FDECEC, #FFF9F0);
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.screen-card.small {
  height: 60rpx;
  width: 70%;
}

.heart-badge {
  position: absolute;
  top: 60rpx;
  right: 80rpx;
  width: 88rpx;
  height: 88rpx;
  background: var(--color-primary);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(160, 48, 31, 0.3);
  animation: pulseHeart 2s ease-in-out infinite;
}

.share-rays {
  position: absolute;
  bottom: 80rpx;
  left: 60rpx;
  width: 120rpx;
  height: 120rpx;
  border: 2rpx dashed rgba(160, 48, 31, 0.2);
  border-radius: 50%;
}

/* 文案 */
.text-block {
  text-align: center;
  padding: 0 20rpx;
  animation: fadeUp 400ms ease 300ms both;
}

.slide-title {
  display: block;
  font-size: 44rpx;
  color: var(--color-text);
  margin-bottom: 24rpx;
  letter-spacing: 4rpx;
}

.slide-subtitle {
  display: block;
  font-size: 28rpx;
  color: var(--color-text-secondary);
  line-height: 1.8;
}

/* 底部 */
.footer {
  padding: 0 48rpx calc(env(safe-area-inset-bottom) + 48rpx);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.dots {
  display: flex;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--color-divider);
  transition: all 300ms ease;
}

.dot.active {
  width: 32rpx;
  border-radius: 6rpx;
  background: var(--color-primary);
}

.hint-text {
  font-size: 24rpx;
  color: var(--color-text-muted);
}

.start-btn {
  width: 100%;
  max-width: 560rpx;
  padding: 28rpx 0;
  text-align: center;
  background: var(--color-primary);
  color: #fff;
  font-size: 30rpx;
  border-radius: var(--radius-pill);
  letter-spacing: 4rpx;
  box-shadow: 0 8rpx 24rpx rgba(160, 48, 31, 0.25);
  transition: transform 200ms ease;
}

.start-btn:active {
  transform: scale(0.96);
}

@keyframes illusFadeIn {
  from { opacity: 0; transform: translateY(24rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes fadeUp {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes floatSoft {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-12rpx); }
}

@keyframes pulseHeart {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.08); }
}
