.page {
  min-height: 100vh;
  padding-bottom: 60rpx;
}

.hero {
  position: relative;
  height: 500rpx;
}

.hero-img {
  width: 100%;
  height: 100%;
}

.hero-mask {
  position: absolute;
  inset: 0;
  background: linear-gradient(transparent 50%, rgba(0,0,0,0.3));
}

.nav-bar {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 24rpx;
  z-index: 10;
}

.nav-btn {
  width: 64rpx;
  height: 64rpx;
  background: rgba(0,0,0,0.35);
  border-radius: 50%;
  color: #fff;
  font-size: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  padding: 0;
  line-height: 1;
}

.nav-btn.active {
  background: #A0301F;
}

.nav-actions {
  display: flex;
  gap: 16rpx;
}

.share-btn {
  margin: 0;
  font-size: 28rpx;
}

.share-btn::after {
  border: none;
}

.content-card {
  margin-top: -50rpx;
  padding: 0 32rpx 40rpx;
  position: relative;
  z-index: 1;
}

.info-card {
  padding: 32rpx;
  margin-bottom: 24rpx;
  border-radius: 24rpx;
}

.title-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.title {
  font-size: 40rpx;
  flex: 1;
}

.stats-row {
  margin: 16rpx 0;
}

.heart-stat {
  color: #E67E22;
  font-size: 24rpx;
  margin-right: 16rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #8B7D6B;
}

.meta-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-top: 16rpx;
}

.meta-item {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #8B7D6B;
}

.meta-icon {
  margin-right: 8rpx;
}

.section-card {
  padding: 32rpx;
  margin-bottom: 24rpx;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(160,48,31,0.06);
}

.body-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.7;
  text-align: justify;
}

.expand-btn {
  display: block;
  text-align: center;
  color: #A0301F;
  font-size: 26rpx;
  margin-top: 16rpx;
}

.video-card {
  position: relative;
  height: 360rpx;
  border-radius: 16rpx;
  overflow: hidden;
  margin-top: 8rpx;
  background: #F0EBE3;
}

.video-poster {
  width: 100%;
  height: 100%;
}

.video-play-mask {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(44, 36, 24, 0.28);
}

.video-play-btn {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: rgba(158, 43, 37, 0.92);
  color: #fff;
  font-size: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding-left: 8rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.2);
}

.video-title {
  display: block;
  font-size: 26rpx;
  color: var(--color-text-secondary, #6B5A48);
  line-height: 1.6;
  margin-top: 16rpx;
}

.video-actions {
  display: flex;
  gap: 24rpx;
  margin-top: 20rpx;
}

.video-action {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  background: var(--color-primary, #9E2B25);
  color: #fff;
  font-size: 26rpx;
  border-radius: 999rpx;
}

.video-action.secondary {
  background: var(--color-bg-cream, #FBF0E0);
  color: var(--color-primary, #9E2B25);
  border: 1rpx solid rgba(158, 43, 37, 0.2);
}

.timeline {
  padding-left: 20rpx;
}

.timeline-item {
  display: flex;
  position: relative;
  padding-bottom: 32rpx;
  padding-left: 32rpx;
  border-left: 2rpx solid #E8E0D0;
}

.timeline-item:last-child {
  border-left-color: transparent;
  padding-bottom: 0;
}

.timeline-dot {
  position: absolute;
  left: -10rpx;
  top: 6rpx;
  width: 18rpx;
  height: 18rpx;
  background: #A0301F;
  border-radius: 50%;
  border: 4rpx solid #FDECEC;
}

.timeline-year {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #A0301F;
}

.timeline-event {
  font-size: 26rpx;
  color: #8B7D6B;
  margin-top: 4rpx;
}

.inherit-block {
  margin-bottom: 20rpx;
}

.inherit-label {
  display: block;
  font-size: 24rpx;
  color: #8B7D6B;
  margin-bottom: 6rpx;
}

.inherit-value {
  font-size: 28rpx;
  line-height: 1.6;
}

.master-card {
  display: flex;
  gap: 24rpx;
  padding-top: 8rpx;
}

.master-card-border {
  padding-bottom: 28rpx;
  margin-bottom: 28rpx;
  border-bottom: 1rpx solid var(--color-divider, #E8E0D0);
}

.master-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  flex-shrink: 0;
  background: var(--color-bg-cream, #F0EBE3);
  border: 2rpx solid rgba(158, 43, 37, 0.12);
}

.master-body {
  flex: 1;
  min-width: 0;
}

.master-head {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.master-name {
  font-size: 32rpx;
}

.master-tag {
  font-size: 20rpx;
  padding: 2rpx 12rpx;
}

.master-intro {
  display: block;
  font-size: 26rpx;
  color: var(--color-text-secondary, #6B5A48);
  line-height: 1.75;
  text-align: justify;
}

.gallery-scroll {
  white-space: nowrap;
  margin-top: 16rpx;
}

.gallery-list {
  display: inline-flex;
  gap: 16rpx;
}

.gallery-img {
  width: 480rpx;
  height: 320rpx;
  border-radius: 16rpx;
  background: #F0EBE3;
}

.recommend-scroll {
  white-space: nowrap;
  margin-top: 16rpx;
}

.recommend-list {
  display: inline-flex;
  gap: 20rpx;
}

.recommend-card {
  display: inline-flex;
  flex-direction: column;
  width: 220rpx;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.rec-cover {
  width: 220rpx;
  height: 160rpx;
  background: #F0EBE3;
}

.rec-name {
  font-size: 26rpx;
  padding: 12rpx 16rpx 4rpx;
}

.rec-city {
  font-size: 22rpx;
  color: #8B7D6B;
  padding: 0 16rpx 16rpx;
}

.section-subtitle {
  display: block;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  margin: -12rpx 0 24rpx;
  line-height: 1.6;
}

.exp-card {
  display: flex;
  gap: 20rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--color-divider);
}

.exp-card:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.exp-cover {
  width: 180rpx;
  height: 180rpx;
  border-radius: var(--radius-md);
  flex-shrink: 0;
  background: var(--color-bg-paper);
}

.exp-info {
  flex: 1;
  min-width: 0;
}

.exp-name {
  display: block;
  font-size: 30rpx;
  margin-bottom: 6rpx;
}

.exp-location {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-muted);
  margin-bottom: 8rpx;
}

.exp-desc {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  line-height: 1.5;
  margin-bottom: 12rpx;
}

.exp-meta {
  margin-bottom: 12rpx;
}

.exp-time,
.exp-status {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-muted);
  line-height: 1.5;
}

.exp-status {
  color: var(--color-primary);
}

.exp-btn {
  display: inline-flex;
  padding: 10rpx 28rpx;
  background: var(--color-primary);
  color: #fff;
  font-size: 24rpx;
  border-radius: var(--radius-pill);
}
