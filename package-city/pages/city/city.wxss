page {
  background: #FFFFFF;
}

.page.city-page:not(.v0-page) {
  min-height: 100vh;
  background: #FFFFFF;
  padding-bottom: 40rpx;
}

.search-bar {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  background: transparent;
  gap: 12rpx;
}

.current-city {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-shrink: 0;
  max-width: 34%;
}

.location-pin {
  width: 28rpx;
  height: 28rpx;
  flex-shrink: 0;
}

.current-city-text {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-text);
  letter-spacing: 1rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.search-input-wrap {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  background: var(--color-card);
  border-radius: 999rpx;
  border: 1rpx solid var(--color-border);
  box-shadow: var(--shadow-soft);
  padding: 16rpx 24rpx;
}

.search-icon {
  color: var(--color-primary);
  margin-right: 12rpx;
  font-size: 28rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
}

.placeholder {
  color: var(--color-text-muted);
}

.search-btn {
  color: var(--color-primary);
  font-size: 28rpx;
  padding: 16rpx 0 16rpx 4rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.locate-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin: 16rpx 0 8rpx;
  padding: 12rpx 20rpx;
  width: fit-content;
  background: #FFFFFF;
  border: 1rpx solid var(--color-border);
  border-radius: 999rpx;
}

.locate-icon {
  width: 28rpx;
  height: 28rpx;
  flex-shrink: 0;
}

.locate-text {
  font-size: 24rpx;
  color: var(--color-primary);
  font-weight: 600;
}

.suggestions {
  background: var(--color-card);
  margin: 0 32rpx;
  border-radius: 16rpx;
  border: 1rpx solid var(--color-border);
  box-shadow: var(--shadow-soft);
  overflow: hidden;
}

.suggestion-item {
  display: flex;
  align-items: center;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid #F0EBE3;
  font-size: 28rpx;
}

.sug-type {
  font-size: 22rpx;
  color: #A0301F;
  background: #FDECEC;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-right: 16rpx;
}

.sug-city {
  margin-left: auto;
  font-size: 24rpx;
  color: #8B7D6B;
}

.history-section {
  padding: 24rpx 32rpx;
}

.history-label {
  font-size: 26rpx;
  color: #8B7D6B;
  margin-bottom: 16rpx;
  display: block;
}

.history-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.history-tag {
  padding: 10rpx 24rpx;
  background: #fff;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: #8B7D6B;
}

.section {
  padding: 32rpx;
}

.section-index {
  padding: 32rpx 80rpx 32rpx 32rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text);
}

.hot-scroll {
  margin-top: 20rpx;
  white-space: nowrap;
}

.hot-scroll-inner {
  display: inline-flex;
  gap: 20rpx;
  padding-bottom: 8rpx;
}

.hot-column {
  display: inline-flex;
  flex-direction: column;
  gap: 20rpx;
  width: 300rpx;
  vertical-align: top;
}

.hot-item {
  text-align: center;
}

.hot-cover {
  width: 300rpx;
  height: 210rpx;
  border-radius: 16rpx;
  background: var(--color-bg-cream);
}

.hot-name {
  font-size: 26rpx;
  margin-top: 12rpx;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.index-list {
  margin-top: 16rpx;
}

.index-group {
  margin-bottom: 24rpx;
}

.index-letter {
  font-size: 28rpx;
  font-weight: 700;
  color: #A0301F;
  margin-bottom: 12rpx;
  display: block;
}

.index-city {
  padding: 24rpx 12rpx 24rpx 0;
  border-bottom: 1rpx solid #E8E0D0;
  font-size: 30rpx;
  border-radius: 12rpx;
  transition: background 0.25s ease;
}

.index-city.active {
  background: rgba(158, 43, 37, 0.08);
}

.side-index {
  position: fixed;
  right: 8rpx;
  top: 50vh;
  transform: translateY(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2rpx;
  z-index: 100;
  padding: 12rpx 4rpx;
  background: #FFFFFF;
  border: 1rpx solid var(--color-border);
  border-radius: 28rpx;
  box-shadow: var(--shadow-soft);
  max-height: 62vh;
  overflow-y: auto;
}

.side-letter {
  width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  flex-shrink: 0;
}

.side-letter-text {
  font-size: 20rpx;
  line-height: 1;
  color: var(--color-text-muted);
  font-weight: 600;
}

.side-letter.active {
  background: var(--color-primary);
}

.side-letter.active .side-letter-text {
  color: #FFFFFF;
}
