/** 非遗寻迹 - 全局视觉规范（继承参考图设计语言） */

page {
  --color-primary: #A0301F;
  --color-primary-dark: #8B2818;
  --color-primary-light: #B34D2E;
  --color-accent: #E67E22;
  --color-bg: #FFF9F0;
  --color-bg-cream: #FDF5E6;
  --color-bg-paper: #F9F3E7;
  --color-card: #FFFFFF;
  --color-text: #1A1A1A;
  --color-text-secondary: #8B7D6B;
  --color-text-muted: #8E8E8E;
  --color-divider: #E8E0D0;
  --color-tag-bg: #FDECEC;
  --color-tag-text: #A0301F;
  --color-white: #FFFFFF;

  --font-serif: "Songti SC", "STSong", "SimSun", serif;
  --font-sans: "Songti SC", "STSong", "SimSun", serif;

  --radius-sm: 8rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  --radius-xl: 40rpx;
  --radius-pill: 999rpx;

  --shadow-card: 0 4rpx 24rpx rgba(160, 48, 31, 0.06);
  --shadow-soft: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);

  --spacing-page: 32rpx;
  --spacing-section: 40rpx;
  --spacing-card: 24rpx;
  --spacing-card-gap: 48rpx; /* 卡片间距，项目之间留白 */
  --spacing-section-head-gap: 72rpx; /* 区块标题 → 首卡，大于卡片间距 */

  --duration-fast: 200ms;
  --duration-normal: 300ms;

  background-color: var(--color-bg);
  color: var(--color-text);
  font-family: var(--font-serif);
  font-size: 28rpx;
  line-height: 1.5;
  box-sizing: border-box;
}

view, text, input, textarea, button {
  font-family: inherit;
}

view, text, image, scroll-view {
  box-sizing: border-box;
}

/* 品牌 Logo */
.logo-img {
  display: block;
  border-radius: 50%;
  flex-shrink: 0;
}

/* 标题 - 宋体/衬线 */
.title-serif {
  font-family: var(--font-serif);
  font-weight: 600;
  color: var(--color-text);
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 24rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.section-more {
  font-size: 24rpx;
  color: var(--color-text-muted);
}

/* 标签 */
.tag-pill {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 16rpx;
  background: var(--color-tag-bg);
  color: var(--color-tag-text);
  font-size: 22rpx;
  border-radius: var(--radius-pill);
  white-space: nowrap;
}

.tag-level {
  background: var(--color-primary);
  color: var(--color-white);
}

/* 按钮 */
.btn-primary {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 40rpx;
  background: var(--color-primary);
  color: var(--color-white);
  font-size: 26rpx;
  border-radius: var(--radius-pill);
  border: none;
  transition: opacity var(--duration-fast);
}

.btn-primary:active {
  opacity: 0.85;
}

.btn-cream {
  background: var(--color-bg-cream);
  color: var(--color-text);
}

/* 内容面板 - 白色圆角底色，用于信息分层 */
.panel-card {
  background: var(--color-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
  padding: 28rpx 32rpx;
}

/* 卡片 */
.card {
  background: var(--color-card);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-card);
  overflow: hidden;
}

/* 分隔线 */
.divider {
  height: 1rpx;
  background: var(--color-divider);
  margin: 24rpx 0;
}

/* 区块标题装饰 - 红色竖条 */
.section-bar-title {
  display: flex;
  align-items: center;
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 20rpx;
}

.section-bar-title::before {
  content: '';
  width: 6rpx;
  height: 28rpx;
  background: var(--color-primary);
  border-radius: 3rpx;
  margin-right: 12rpx;
}

.section-bar-title--inline {
  margin-bottom: 0;
}

.section-header-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.heritage-section .section-header-bar {
  margin-bottom: var(--spacing-section-head-gap, 72rpx);
}

.section-count {
  font-size: 26rpx;
  color: var(--color-text-muted);
}

/* 非遗列表 - 卡片之间用 gap 控制间距 */
.heritage-list {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-card-gap, 48rpx);
}

/* 空状态 */
.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 60rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
  opacity: 0.4;
}

.empty-text {
  font-size: 28rpx;
  color: var(--color-text-muted);
  text-align: center;
}

/* 页面淡入 */
.page-fade-in {
  animation: fadeIn var(--duration-normal) ease;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(12rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* 点击反馈 */
.tap-active:active {
  opacity: 0.88;
  transform: scale(0.98);
  transition: all var(--duration-fast);
}

/* 安全区域 */
.safe-bottom {
  padding-bottom: calc(env(safe-area-inset-bottom) + 120rpx);
}

/* 文本省略 */
.ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ellipsis-2 {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.ellipsis-3 {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
  overflow: hidden;
}
