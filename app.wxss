/** 非遗寻迹 - 中国风视觉规范（宣纸 · 朱砂 · 墨色） */

page {
  --color-primary: #9E2B25;
  --color-primary-dark: #7A201C;
  --color-primary-light: #C14E42;
  --color-accent: #A67C3D;
  --color-accent-light: #D4B896;
  --color-bg-top: #F5DCC0;
  --color-bg-bottom: #FFFFFF;
  --color-bg: #F5DCC0;
  --app-bg-gradient: linear-gradient(180deg, #F5DCC0 0%, #FFF5E8 50%, #FFFFFF 100%);
  --color-bg-cream: #FBF0E0;
  --color-bg-paper: #F5E5CE;
  --color-card: #FFFBF5;
  --color-text: #2C2418;
  --color-text-secondary: #6B5A48;
  --color-text-muted: #8A7968;
  --color-text-body: #50463C;
  --color-divider: rgba(44, 36, 24, 0.1);
  --color-border: rgba(158, 43, 37, 0.12);
  --color-tag-bg: rgba(158, 43, 37, 0.08);
  --color-tag-text: #9E2B25;
  --color-white: #FFFFFF;

  --font-serif: "Songti SC", "STSong", "SimSun", serif;
  --font-sans: "Songti SC", "STSong", "SimSun", serif;

  --radius-sm: 8rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  --radius-xl: 40rpx;
  --radius-pill: 999rpx;

  --shadow-card: 0 8rpx 32rpx rgba(44, 36, 24, 0.06);
  --shadow-soft: 0 2rpx 16rpx rgba(44, 36, 24, 0.04);

  --spacing-page: 32rpx;
  --spacing-section: 40rpx;
  --spacing-card: 24rpx;
  --spacing-card-gap: 48rpx;
  --spacing-section-head-gap: 72rpx;

  --duration-fast: 200ms;
  --duration-normal: 300ms;

  background: var(--app-bg-gradient);
  color: var(--color-text);
  font-family: var(--font-serif);
  font-size: 28rpx;
  line-height: 1.6;
  box-sizing: border-box;
}

view, text, input, textarea, button {
  font-family: inherit;
}

view, text, image, scroll-view {
  box-sizing: border-box;
}

/* 品牌 Logo */
.logo-img {
  display: block;
  border-radius: 50%;
  flex-shrink: 0;
}

/* 标题 - 宋体/衬线 */
.title-serif {
  font-family: var(--font-serif);
  font-weight: 700;
  color: var(--color-text);
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 24rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.section-more {
  font-size: 24rpx;
  color: var(--color-text-muted);
}

/* 标签 */
.tag-pill {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 16rpx;
  background: var(--color-tag-bg);
  color: var(--color-tag-text);
  font-size: 22rpx;
  border-radius: var(--radius-pill);
  white-space: nowrap;
}

.tag-level {
  background: var(--color-primary);
  color: var(--color-white);
}

/* 按钮 */
.btn-primary {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 40rpx;
  background: var(--color-primary);
  color: var(--color-white);
  font-size: 26rpx;
  border-radius: var(--radius-pill);
  border: none;
  transition: opacity var(--duration-fast);
}

.btn-primary:active {
  opacity: 0.85;
}

.btn-cream {
  background: var(--color-bg-cream);
  color: var(--color-text);
}

/* 内容面板 */
.panel-card {
  background: var(--color-card);
  border-radius: var(--radius-lg);
  border: 1rpx solid var(--color-border);
  box-shadow: var(--shadow-card);
  padding: 28rpx 32rpx;
}

/* 卡片 */
.card {
  background: var(--color-card);
  border-radius: var(--radius-md);
  border: 1rpx solid var(--color-border);
  box-shadow: var(--shadow-card);
  overflow: hidden;
}

/* 分隔线 */
.divider {
  height: 1rpx;
  background: var(--color-divider);
  margin: 24rpx 0;
}

/* 区块标题装饰 - 红色竖条 */
.section-bar-title {
  display: flex;
  align-items: center;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 20rpx;
}

.section-bar-title::before {
  content: '';
  width: 6rpx;
  height: 28rpx;
  background: linear-gradient(180deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
  border-radius: 3rpx;
  margin-right: 12rpx;
}

.section-bar-title--inline {
  margin-bottom: 0;
}

.section-header-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.heritage-section .section-header-bar {
  margin-bottom: var(--spacing-section-head-gap, 72rpx);
}

.section-count {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

/* 非遗列表 - 卡片之间用 gap 控制间距 */
.heritage-list {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-card-gap, 48rpx);
}

/* 空状态 */
.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 60rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
  opacity: 0.4;
}

.empty-text {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  text-align: center;
}

/* 页面暖色渐变背景（与 page 一致，用于全屏容器） */
.app-bg-gradient {
  background: var(--app-bg-gradient);
}

.page {
  min-height: 100vh;
}

/* 非 v0 子页面：渐变铺满整页（随内容增高拉伸，避免滚动断层） */
.page:not(.v0-page) {
  background: var(--app-bg-gradient);
  min-height: 100vh;
}

/* v0 主页面：一体简写渐变，避免与 transparent 简写冲突 */
.page.v0-page {
  background: var(--app-bg-gradient);
}

.page-fade-in {
  opacity: 1;
  animation: fadeIn var(--duration-normal) ease forwards;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(12rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* 点击反馈 */
.tap-active:active {
  opacity: 0.88;
  transform: scale(0.98);
  transition: all var(--duration-fast);
}

/* 安全区域 */
.safe-bottom {
  padding-bottom: calc(env(safe-area-inset-bottom) + 120rpx);
}

/* 文本省略 */
.ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ellipsis-2 {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.ellipsis-3 {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
  overflow: hidden;
}
